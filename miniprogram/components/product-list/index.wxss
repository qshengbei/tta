.product-list {
  padding: 0 24rpx 24rpx;
}

.product-list__grid {
  display: flex;
  flex-wrap: wrap;
  justify-content: space-between;
}

.product-list__grid-item {
  width: calc(50% - 12rpx);
  margin-bottom: 24rpx;
}

.product-list__list {
  display: flex;
  flex-direction: column;
}

.product-list__list-item {
  margin-bottom: 24rpx;
}