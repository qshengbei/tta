.cart-preview {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 1000;
  display: flex;
  flex-direction: column;
  justify-content: flex-end;
}

.cart-preview__overlay {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(0, 0, 0, 0.5);
}

.cart-preview__content {
  position: relative;
  background-color: #fff;
  border-top-left-radius: 24rpx;
  border-top-right-radius: 24rpx;
  max-height: 80vh;
  display: flex;
  flex-direction: column;
  animation: slide-up 0.3s ease-out;
}

@keyframes slide-up {
  from {
    transform: translateY(100%);
  }
  to {
    transform: translateY(0);
  }
}

.cart-preview__header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 32rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.cart-preview__header-left {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

/* 提示文字 */
.cart-preview__hint {
  animation: fadeIn 0.3s ease;
}

.cart-preview__hint text {
  font-size: 24rpx;
  color: #999;
  display: block;
  padding-top:2rpx;
}

@keyframes fadeIn {
  from {
    opacity: 0;
    transform: translateY(-5rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

.cart-preview__title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
}

.cart-preview__close {
  font-size: 48rpx;
  color: #999;
  line-height: 1;
  padding: 0 16rpx;
}

.cart-preview__body {
  flex: 1;
  overflow-y: auto;
  padding: 0 32rpx;
}

.cart-preview__empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 80rpx 0;
  color: #999;
}

.cart-preview__items {
  padding: 16rpx 0;
}

.cart-preview__item-container {
  position: relative;
  margin-bottom: 20rpx;
  height: 200rpx;
  overflow: hidden;
  border-radius: 12rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
}

.cart-preview__item {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  display: flex;
  padding: 20rpx;
  box-sizing: border-box;
  background-color: #fff;
  transition: transform 0.3s ease;
  z-index: 1;
  pointer-events: auto;
  align-items: center;
}

/* 删除按钮 */
.cart-preview__item-delete {
  position: absolute;
  top: 0;
  right: 0;
  bottom: 0;
  width: 180rpx;
  background-color: #ff4d4f;
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 0;
  pointer-events: auto;
}

.cart-preview__item-delete-text {
  font-size: 28rpx;
  color: #fff;
  font-weight: 500;
}

.cart-preview__item:last-child {
  border-bottom: none;
}

.cart-preview__item-image {
  width: 120rpx;
  height: 120rpx;
  border-radius: 8rpx;
  margin-right: 24rpx;
}

.cart-preview__item-info {
  flex: 1;
  min-width: 0;
}

.cart-preview__item-name {
  font-size: 28rpx;
  color: #333;
  margin-bottom: 12rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
}

.cart-preview__item-price {
  font-size: 28rpx;
  font-weight: 600;
  color: #000;
}

.cart-preview__item-quantity {
  font-size: 24rpx;
  color: #999;
  margin-left: 24rpx;
}

.cart-preview__footer {
  padding: 32rpx;
  border-top: 1rpx solid #f0f0f0;
  background-color: #fff;
}

.cart-preview__btn {
  width: 100%;
  height: 96rpx;
  background-color: #000;
  color: #fff;
  border-radius: 48rpx;
  font-size: 32rpx;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
}

.cart-preview__btn::after {
  border: none;
}
