<view class="order-card" bindtap="onTap">
  <view class="order-card__header">
    <view class="order-card__no">
      订单号：{{order.orderNo}}
    </view>
    <view class="order-card__status">
      {{statusText}}
    </view>
  </view>

  <view class="order-card__body">
    <view class="order-card__products">
      <block wx:for="{{order.items}}" wx:key="productId">
        <view class="order-card__product-line">
          <text class="order-card__product-name text-ellipsis">
            {{item.name}}
          </text>
          <text class="order-card__product-qty">
            x{{item.quantity}}
          </text>
        </view>
      </block>
    </view>
  </view>

  <view class="order-card__footer">
    <text class="order-card__amount">
      合计：￥{{(order.amountTotal || 0) / 100}}
    </text>
    <view class="order-card__meta text-secondary">
      {{order.createdAtText}}
    </view>
  </view>
</view>