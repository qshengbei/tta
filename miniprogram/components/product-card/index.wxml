<view class="product-card">
  <image class="product-card__image" src="{{product.coverImage}}" mode="aspectFill"/>
  <view class="product-card__info">
    <text class="product-card__name">{{product.name}}</text>
    <view class="product-card__bottom">
      <text class="product-card__price">¥{{product.price}}</text>
      <text class="product-card__stock" wx:if="{{product.stock > 0}}">库存: {{product.stock}}</text>
      <text class="product-card__stock product-card__stock--soldout" wx:else>售罄</text>
    </view>
  </view>
</view>