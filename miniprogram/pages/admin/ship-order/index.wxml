<!-- pages/admin/ship-order/index.wxml -->
<view class="ship-order">
  <view class="ship-order__header">
    <view class="ship-order__header-left"></view>
    <view class="ship-order__header-title"></view>
    <view class="ship-order__header-right"></view>
  </view>
  
  <view class="ship-order__content">
    <!-- 订单信息 -->
    <view class="ship-order__order-info">
      <text class="ship-order__order-label">订单号：</text>
      <text class="ship-order__order-value">{{orderInfo.orderNumber}}</text>
    </view>
    
    <view class="ship-order__order-info">
      <text class="ship-order__order-label">订单金额：</text>
      <text class="ship-order__order-value">¥{{orderInfo.totalPrice || '0.00'}}</text>
    </view>
    
    <!-- 物流信息 -->
    <view class="ship-order__logistics-section">
      <text class="ship-order__section-title">物流信息</text>
      
      <!-- 快递公司选择 -->
      <view class="ship-order__form-item">
        <text class="ship-order__form-label">快递公司：</text>
        <view class="ship-order__form-select" bindtap="showCompanyPicker">
          <text class="ship-order__form-select-value">{{selectedCompany ? selectedCompany.name : '请选择快递公司'}}</text>
          <text class="ship-order__form-select-arrow">▼</text>
        </view>
      </view>
      
      <!-- 快递单号输入 -->
      <view class="ship-order__form-item">
        <text class="ship-order__form-label">快递单号：</text>
        <input class="ship-order__form-input" placeholder="请输入快递单号" value="{{trackingNumber}}" bindinput="inputTrackingNumber" />
      </view>
      
      <!-- 发货地址选择 -->
      <view class="ship-order__form-item">
        <text class="ship-order__form-label">发货地址：</text>
        <view class="ship-order__form-select" bindtap="showAddressPicker">
          <text class="ship-order__form-select-value">{{selectedAddress ? selectedAddress.address : '请选择发货地址'}}</text>
          <text class="ship-order__form-select-arrow">▼</text>
        </view>
      </view>
    </view>
    
    <!-- 发货按钮 -->
    <button class="ship-order__submit-btn" bindtap="submitShip" disabled="{{!selectedCompany || !trackingNumber || !selectedAddress || submitting}}">
      {{submitting ? '发货中...' : '确认发货'}}
    </button>
  </view>
  
  <!-- 快递公司选择器 -->
  <view class="ship-order__picker" wx:if="{{showCompanyPicker}}">
    <view class="ship-order__picker-mask" bindtap="hideCompanyPicker"></view>
    <view class="ship-order__picker-content">
      <view class="ship-order__picker-header">
        <text class="ship-order__picker-cancel" bindtap="hideCompanyPicker">取消</text>
        <text class="ship-order__picker-title">选择快递公司</text>
        <text class="ship-order__picker-confirm" bindtap="confirmCompany">确定</text>
      </view>
      <picker-view class="ship-order__picker-view" indicator-style="height: 50px;" style="width: 100%; height: 300px;" value="{{companyPickerValue}}" bindchange="companyPickerChange">
        <picker-view-column>
          <view wx:for="{{expressCompanies}}" wx:key="code" style="height: 50px; line-height: 50px; text-align: center;">{{item.name}}</view>
        </picker-view-column>
      </picker-view>
    </view>
  </view>
  
  <!-- 发货地址选择器 -->
  <view class="ship-order__picker" wx:if="{{showAddressPicker}}">
    <view class="ship-order__picker-mask" bindtap="hideAddressPicker"></view>
    <view class="ship-order__picker-content">
      <view class="ship-order__picker-header">
        <text class="ship-order__picker-cancel" bindtap="hideAddressPicker">取消</text>
        <text class="ship-order__picker-title">选择发货地址</text>
        <text class="ship-order__picker-confirm" bindtap="confirmAddress">确定</text>
      </view>
      <picker-view class="ship-order__picker-view" indicator-style="height: 50px; line-height: 50px; text-align: center;" style="width: 100%; height: 300px;" value="{{addressPickerValue}}" bindchange="addressPickerChange">
        <picker-view-column>
          <view wx:for="{{deliveryAddresses}}" wx:key="index" style="height: 50px; line-height: 50px; text-align: center;">{{item.address}}</view>
        </picker-view-column>
      </picker-view>
    </view>
  </view>
</view>