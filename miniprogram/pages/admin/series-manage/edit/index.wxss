/* pages/admin/series-manage/edit/index.wxss */
page {
  background-color: var(--color-bg);
  padding: 0;
  margin: 0;
}

.series-edit {
  background-color: var(--color-bg);
  min-height: 100vh;
  padding-top: 0;
  margin-top: 0;
}

/* 商品表单 */
.product-form {
  padding: 0 14rpx;
  padding-bottom: 140rpx;
  margin: 0;
  position: relative;
  top: -35rpx;
}

/* 表单元素 */
form {
  margin: 0;
  padding: 0;
}

/* 表单项目 */
.form-item {
  background-color: white;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.05);
  transition: all 0.3s ease;
}

.form-item:active {
  transform: translateY(2rpx);
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.05);
}

.form-item__label {
  font-size: 26rpx;
  font-weight: 500;
  color: #2c3e50;
  margin-bottom: 16rpx;
  display: block;
  letter-spacing: 0.5rpx;
}

.form-item__input {
  font-size: 26rpx;
  color: #2c3e50;
  padding: 0 20rpx;
  border: 1rpx solid #e6e9ed;
  border-radius: 12rpx;
  background-color: #fafbfc;
  transition: all 0.3s ease;
  width: 100%;
  box-sizing: border-box;
  height: 80rpx;
  line-height: 80rpx;
  display: flex;
  align-items: center;
}

.form-item__input:focus {
  border-color: #95a5a6;
  background-color: white;
}

/* picker样式 */
.form-item__picker {
  font-size: 26rpx;
  color: #2c3e50;
  padding: 0 20rpx;
  border: 1rpx solid #e6e9ed;
  border-radius: 12rpx;
  background-color: #fafbfc;
  transition: all 0.3s ease;
  width: 100%;
  box-sizing: border-box;
  height: 80rpx;
  line-height: 80rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.picker-arrow {
  font-size: 20rpx;
  color: #95a5a6;
}

.image-uploader {
  display: flex;
  align-items: center;
}

.image-uploader__preview {
  position: relative;
  width: 200rpx;
  height: 200rpx;
  border-radius: 12rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.1);
}

.image-uploader__preview-image {
  width: 100%;
  height: 100%;
  object-fit: cover;
}

.image-uploader__preview-remove {
  position: absolute;
  top: 8rpx;
  right: 8rpx;
  width: 36rpx;
  height: 36rpx;
  background-color: rgba(255, 255, 255, 0.9);
  color: #e74c3c;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  cursor: pointer;
  border-radius: 50%;
  box-shadow: 0 2rpx 6rpx rgba(0, 0, 0, 0.15);
  transition: all 0.3s ease;
}

.image-uploader__preview-remove:active {
  transform: scale(0.9);
}

.image-uploader__upload {
  width: 200rpx;
  height: 200rpx;
  border: 2rpx dashed #dce4ec;
  border-radius: 12rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  background-color: #f8f9fa;
  cursor: pointer;
  transition: all 0.3s ease;
}

.image-uploader__upload:active {
  background-color: #e9ecef;
}

.image-uploader__upload-icon {
  width: 48rpx;
  height: 48rpx;
  margin-bottom: 12rpx;
}

.image-uploader__upload-text {
  font-size: 20rpx;
  color: #95a5a6;
}

/* 固定在底部的保存按钮 */
.fixed-submit {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 24rpx;
  background: rgba(255, 255, 255, 0.8);
  backdrop-filter: blur(10rpx);
  -webkit-backdrop-filter: blur(10rpx);
  border-top: 1rpx solid rgba(229, 231, 235, 0.8);
  z-index: 100;
}

.submit-button {
  width: 100%;
  height: 92rpx;
  font-size: 32rpx;
  font-weight: 500;
  border-radius: 46rpx;
  background-color: #2c3e50;
  color: white;
  box-shadow: 0 6rpx 20rpx rgba(44, 62, 80, 0.3);
  transition: all 0.3s ease;
  display: flex;
  align-items: center;
  justify-content: center;
}

.submit-button:active {
  transform: translateY(2rpx);
  box-shadow: 0 3rpx 10rpx rgba(44, 62, 80, 0.3);
}

.submit-button::after {
  border: none;
}

/* 响应式设计 */
@media (min-width: 750rpx) {
  .form-item {
    padding: 28rpx;
  }
  
  .form-item__label {
    font-size: 28rpx;
  }
  
  .form-item__input {
    font-size: 28rpx;
  }
}
