.banner-manage {
  min-height: 100vh;
  background-color: #f5f5f5;
}

.header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 30rpx;
  background-color: #ffffff;
  border-bottom: 1rpx solid #eee;
}

.title {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
}

.add-btn {
  padding: 10rpx 20rpx;
  background-color: #ff6b6b;
  color: #fff;
  border-radius: 8rpx;
  font-size: 28rpx;
  border: none;
}

.banner-list {
  padding: 20rpx;
}

.loading, .empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 100rpx 0;
}

.empty-text {
  font-size: 28rpx;
  color: #999;
  margin-bottom: 20rpx;
}

.empty-btn {
  padding: 15rpx 30rpx;
  background-color: #ff6b6b;
  color: #fff;
  border-radius: 8rpx;
  font-size: 28rpx;
  border: none;
}

.list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.banner-item {
  background-color: #fff;
  border-radius: 12rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.05);
}

.banner-image-wrapper {
  width: 100%;
  position: relative;
  background-color: #f5f5f5;
}

.banner-image {
  width: 100%;
  height: auto;
  min-height: 200rpx;
  display: block;
}

.banner-info {
  padding: 20rpx;
}

.banner-link {
  font-size: 26rpx;
  color: #666;
  display: block;
  margin-bottom: 10rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.banner-status {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.sort-order {
  font-size: 24rpx;
  color: #999;
}

.status-switch {
  transform: scale(0.8);
}

.banner-actions {
  display: flex;
  border-top: 1rpx solid #eee;
}

.action-btn {
  flex: 1;
  padding: 20rpx;
  background-color: transparent;
  border: none;
  font-size: 28rpx;
}

.edit-btn {
  color: #ff6b6b;
  border-right: 1rpx solid #eee;
}

.delete-btn {
  color: #999;
}