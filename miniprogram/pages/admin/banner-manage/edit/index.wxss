page {
  min-height: 100vh;
  background-color: #ffffff;
}

.edit-page {
  min-height: 100vh;
  background-color: #ffffff;
}

/* 表单内容 */
.form-content {
  padding: 20rpx 30rpx 160rpx;
  box-sizing: border-box;
}

.form-item {
  margin-bottom: 0;
  padding: 30rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.form-label {
  display: block;
  font-size: 28rpx;
  color: #333;
  margin-bottom: 15rpx;
  font-weight: 500;
}

.image-upload {
  width: 100%;
  min-height: 400rpx;
  border: 2rpx dashed #ddd;
  border-radius: 12rpx;
  display: flex;
  align-items: flex-start;
  justify-content: center;
  background-color: #fafafa;
  box-sizing: border-box;
}

.uploaded-image {
  width: 100%;
  height: auto;
  display: block;
  border-radius: 12rpx;
}

.upload-placeholder {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 100rpx 0;
}

.upload-text {
  font-size: 26rpx;
  color: #999;
  margin-top: 10rpx;
}

.upload-icon {
  font-size: 60rpx;
  color: #ccc;
}

.form-input {
  width: 100%;
  height: 80rpx;
  padding: 0 20rpx;
  background-color: #fafafa;
  border-radius: 8rpx;
  font-size: 28rpx;
  box-sizing: border-box;
}

.form-item:last-child {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding-right: 30rpx;
}

.form-switch {
  transform: scale(0.9);
}

/* 底部悬浮按钮 */
.submit-btn-wrapper {
  position: fixed;
  bottom: 30rpx;
  left: 30rpx;
  right: 30rpx;
  z-index: 100;
}

.submit-btn {
  width: 100%;
  height: 88rpx;
  background-color: #ff6b6b;
  color: #fff;
  border-radius: 44rpx;
  font-size: 32rpx;
  border: none;
  padding: 0;
  min-height: auto;
  display: flex;
  align-items: center;
  justify-content: center;
}

.submit-btn::after {
  border: none;
}