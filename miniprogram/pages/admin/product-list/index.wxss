/* pages/product-list/index.wxss */

.products-list-page {
  min-height: 100vh;
  background-color: #f8f8f8;
}

/* 排序选项 */
.sort-options {
  display: flex;
  background-color: #fff;
  padding: 0 32rpx;
  height: 72rpx;
  align-items: center;
  border-bottom: 1rpx solid #f0f0f0;
  justify-content: flex-start;
}

.add-button {
  width: 48rpx;
  height: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-left: auto;
  cursor: pointer;
}

.add-icon {
  width: 24rpx;
  height: 24rpx;
}

.sort-option {
  display: flex;
  align-items: center;
  margin-right: 48rpx;
  cursor: pointer;
}

.sort-text {
  font-size: 24rpx;
  color: #666;
  transition: all 0.3s ease;
}

.sort-option--active .sort-text {
  color: #000;
  font-weight: 500;
}

.sort-icon {
  width: 20rpx;
  height: 20rpx;
  margin-left: 8rpx;
}

/* 商品列表滚动容器 */
.products-scroll {
  height: calc(100vh - 166rpx);
}

/* 商品列表 */
.products-list {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 20rpx;
  padding: 20rpx;
}

/* 没有更多商品提示 */
.no-more {
  grid-column: 1 / -1;
  text-align: center;
  padding: 40rpx 0;
  color: #999;
  font-size: 28rpx;
  background-color: #f8f8f8;
}

.product-item {
  border-radius: 12rpx;
  overflow: hidden;
  transition: all 0.3s ease;
  display: flex;
  flex-direction: column;
  background-color: transparent;
}

.product-item:active {
  transform: translateY(2rpx);
}

.product-content {
  padding: 16rpx;
  flex: 1;
  background-color: #fff;
  border-radius: 12rpx 12rpx 0 0;
}

.product-actions {
  display: flex;
  border-top: 1rpx solid #f0f0f0;
  background-color: #fff;
  border-radius: 0 0 12rpx 12rpx;
}

.action-button-down {
  flex: 1;
  padding: 12rpx;
  text-align: center;
  background-color: #f0f0f0;
  border-right: 1rpx solid #e0e0e0;
  cursor: pointer;
}

.action-button-edit {
  flex: 1;
  padding: 12rpx;
  text-align: center;
  background-color: #f0f0f0;
  cursor: pointer;
}

.action-button-text {
  font-size: 24rpx;
  color: #666;
}

.product-image-container {
  width: 100%;
  aspect-ratio: 1;
  position: relative;
  border-radius: 12rpx;
  overflow: hidden;
}

.product-image {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  object-fit: cover;
}

.product-sold-out {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(0, 0, 0, 0.3);
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.product-sold-out-text {
  font-size: 28rpx;
  font-weight: 600;
  color: #fff;
  transform: rotate(-30deg);
  text-shadow: 0 2rpx 4rpx rgba(0, 0, 0, 0.3);
}

.product-info {
  padding: 12rpx 0 0 0;
  text-align: left;
}

.product-name {
  font-size: 24rpx;
  color: #333;
  margin-bottom: 4rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  max-width: 100%;
  display: block;
}

.price-and-tag {
  display: flex;
  align-items: center;
  justify-content: flex-start;
}

.product-price {
  font-size: 28rpx;
  font-weight: 600;
  color: #000;
  margin-right: 8rpx;
}

.new-tag {
  width: 40rpx;
  height: 40rpx;
  margin-left: 8rpx;
}

/* 空状态 */
.empty-state {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 400rpx;
  background-color: #fff;
  margin: 20rpx;
  border-radius: 12rpx;
}

.empty-text {
  font-size: 24rpx;
  color: #999;
}

/* 响应式设计 */
@media (min-width: 750rpx) {
  .products-list {
    grid-template-columns: repeat(3, 1fr);
  }
}

/* 横屏模式 */
@media (orientation: landscape) {
  .sort-options {
    height: 60rpx;
  }
}