<!-- pages/admin/user-manage/index.wxml -->
<view class="user-manage">
  <!-- 用户列表 -->
  <view class="user-list">
    <view wx:for="{{users}}" wx:key="_id" class="user-item">
      <image class="user-item__avatar" src="{{item.avatarImage || '../../../images/icons/默认头像.png'}}" mode="aspectFill"></image>
      <view class="user-item__info">
        <text class="user-item__name">{{item.nickName || '未知用户'}}</text>
        <text class="user-item__created">注册时间: {{item.createdAt}}</text>
      </view>
      <button class="user-item__action-button" data-id="{{item._id}}" bindtap="viewUserDetail">查看详情</button>
    </view>
    
    <!-- 空状态 -->
    <view wx:if="{{users.length === 0 && !loading}}" class="empty-state">
      <text class="empty-state__text">暂无用户</text>
    </view>
    
    <!-- 加载状态 -->
    <view wx:if="{{loading}}" class="loading-state">
      <text class="loading-state__text">加载中...</text>
    </view>
  </view>
</view>
