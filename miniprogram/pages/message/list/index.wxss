.message-container {
  min-height: 100vh;
  background-color: #f8f8f8;
}

/* 顶部操作栏 */
.message-header {
  display: flex;
  justify-content: flex-end;
  align-items: center;
  padding: 20rpx 32rpx;
  background-color: #f8f8f8;
  gap: 40rpx;
}

.header-left {
  width: 60rpx;
  display: flex;
  align-items: center;
  justify-content: flex-start;
  margin-right: auto;
}

.back-icon {
  width: 32rpx;
  height: 32rpx;
  transform: rotate(180deg);
}

.mark-all-read {
  font-size: 24rpx;
  color: #6b7280;
  transition: color 0.2s ease;
}

.mark-all-read:active {
  color: #374151;
}

/* 区域容器 */
.section-container {
  margin-top: 0rpx;
  background-color: #f8f8f8;
}

/* 通知列表 */
.notification-list {
  overflow-y: auto;
  width: 100%;
  box-sizing: border-box;
  height: calc(100vh - 120rpx);
  position: relative;
}

.swipe-row {
  position: relative;
  margin: 0 24rpx 16rpx;
  overflow: hidden;
  border-radius: 16rpx;
}

.swipe-actions {
  position: absolute;
  top: 0;
  right: 0;
  bottom: 0;
  display: flex;
  align-items: stretch;
  justify-content: flex-end;
  transform: translateX(100%);
  transition: transform 0.2s ease;
  will-change: transform;
  z-index: 1;
}

.swipe-row-open .swipe-actions {
  transform: translateX(0);
}

.swipe-actions-double {
  width: 264rpx;
}

.swipe-action {
  width: 132rpx;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #ffffff;
  font-size: 24rpx;
}

.swipe-action-unread {
  background-color: #2563eb;
}

.swipe-action-delete {
  background-color: #ef4444;
}

.swipe-card {
  margin: 0;
  width: 100%;
  transition: transform 0.2s ease, box-shadow 0.2s ease;
  position: relative;
  z-index: 2;
}

.swipe-card-open-double {
  transform: translateX(-264rpx);
}

/* 底部提示 */
.message-footer {
  padding: 48rpx 0;
  text-align: center;
}

.footer-text {
  font-size: 18rpx;
  color: #9ca3af;
}

.notification-item {
  display: flex;
  align-items: flex-start;
  padding: 24rpx 32rpx;
  background-color: #ffffff;
  border-radius: 16rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
  position: relative;
  transition: transform 0.2s ease, box-shadow 0.2s ease;
}

.notification-item:active {
  transform: translateY(2rpx);
  box-shadow: 0 1rpx 4rpx rgba(0, 0, 0, 0.05);
}

.unread-badge {
  width: 10rpx;
  height: 10rpx;
  background-color: #ef4444;
  border-radius: 50%;
  margin-right: 16rpx;
  margin-top: 12rpx;
}

.notification-content {
  flex: 1;
  box-sizing: border-box;
}

.notification-info {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  margin-bottom: 8rpx;
  width: 100%;
  box-sizing: border-box;
  overflow: hidden;
}

.notification-title {
  font-size: 26rpx;
  font-weight: 600;
  color: #1f2937;
  flex: 1;
  margin-right: 16rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  box-sizing: border-box;
}

.notification-time {
  font-size: 18rpx;
  color: #9ca3af;
  white-space: nowrap;
  flex-shrink: 0;
  box-sizing: border-box;
}

.notification-text {
  font-size: 22rpx;
  color: #6b7280;
  line-height: 32rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  box-sizing: border-box;
  margin-bottom: 8rpx;
}

.notification-role-tag {
  display: inline-block;
  padding: 4rpx 12rpx;
  background-color: #f3f4f6;
  color: #6b7280;
  font-size: 18rpx;
  border-radius: 12rpx;
  margin-top: 8rpx;
}

/* 空状态 */
.empty-notification {
  padding: 120rpx 0;
  text-align: center;
  background-color: #f8f8f8;
}

.empty-text {
  font-size: 24rpx;
  color: #9ca3af;
  margin-bottom: 48rpx;
}

/* 加载更多 */
.loading-more {
  padding: 32rpx 0;
  text-align: center;
  background-color: #f8f8f8;
}

.loading-text {
  font-size: 24rpx;
  color: #9ca3af;
}

/* 没有更多 */
.no-more {
  padding: 32rpx 0;
  text-align: center;
  background-color: #f8f8f8;
}

.no-more-text {
  font-size: 24rpx;
  color: #9ca3af;
}

/* 加载更多按钮 */
.load-more-btn-wrap {
  padding: 24rpx 0;
  text-align: center;
  background-color: #f8f8f8;
}

.load-more-btn {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 16rpx 48rpx;
  background-color: #ffffff;
  border-radius: 40rpx;
  border: 1rpx solid #e5e7eb;
  transition: all 0.2s ease;
}

.load-more-btn:active {
  background-color: #f3f4f6;
}

.load-more-text {
  font-size: 24rpx;
  color: #6b7280;
}
