<view class="page-root">
  <view wx:if="{{loading}}" class="loading">
    <view class="loading__spinner"></view>
    <text class="loading__text">加载中...</text>
  </view>

  <view wx:elif="{{error}}" class="error">
    <text class="error__text">{{errorMessage}}</text>
    <button class="btn btn-secondary" bindtap="reload">重试</button>
  </view>

  <view wx:else class="order-list">
    <view wx:if="{{orders.length === 0}}" class="empty">
      <text class="empty__text">暂无订单</text>
      <button class="btn btn-primary" bindtap="goToHome">去购物</button>
    </view>
    
    <view wx:else class="orders">
      <view wx:for="{{orders}}" wx:key="{{item._id}}" class="order-item">
        <view class="order-item__header">
          <text class="order-item__order-number">订单号：{{item.orderNumber}}</text>
          <text class="order-item__status">{{item.statusText}}</text>
        </view>
        
        <view class="order-item__content">
          <image class="order-item__image" src="{{item.product.coverImage}}" mode="aspectFill"/>
          <view class="order-item__info">
            <text class="order-item__name">{{item.product.name}}</text>
            <view class="order-item__bottom">
              <text class="order-item__price">¥{{item.product.price}}</text>
              <text class="order-item__quantity">x{{item.quantity}}</text>
            </view>
          </view>
        </view>
        
        <view class="order-item__footer">
          <text class="order-item__total">合计：¥{{item.totalPrice}}</text>
          <button class="order-item__btn" bindtap="viewOrderDetail" data-order-id="{{item._id}}">
            查看详情
          </button>
        </view>
      </view>
    </view>
  </view>
</view>