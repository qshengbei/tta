.page-root {
  width: 100%;
  height: 100%;
  background-color: #f5f5f5;
  overflow: hidden;
  display: flex;
  flex-direction: column;
}

/* 订单状态标签栏 */
.status-tabs {
  background: rgba(255, 255, 255, 0.8);
  backdrop-filter: blur(10px);
  -webkit-backdrop-filter: blur(10px);
  border-bottom: 1rpx solid rgba(255, 255, 255, 0.3);
  position: sticky;
  top: 0;
  z-index: 100;
}

.status-tabs__container {
  display: flex;
  overflow-x: auto;
  white-space: nowrap;
  padding: 0 16rpx;
  -webkit-overflow-scrolling: touch;
}

.status-tabs__item {
  padding: 24rpx 28rpx;
  font-size: 24rpx;
  color: #666;
  position: relative;
  cursor: pointer;
}

.status-tabs__item--active {
  color: #000;
  font-weight: 500;
}

.status-tabs__item--active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 28rpx;
  right: 28rpx;
  height: 4rpx;
  background-color: #000;
  border-radius: 2rpx;
}

.order-list {
  flex: 1;
  overflow-y: auto;
}

/* 加载状态 */
.loading {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  background-color: #f5f5f5;
}

.loading__spinner {
  width: 60rpx;
  height: 60rpx;
  border-radius: 50%;
  border: 6rpx solid #e0e0e0;
  border-top-color: #000;
  animation: spin 1s linear infinite;
  margin-bottom: 20rpx;
}

.loading__text {
  font-size: 24rpx;
  color: #666;
}

/* 错误状态 */
.error {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  background-color: #f5f5f5;
  padding: 40rpx;
}

.error__text {
  font-size: 24rpx;
  color: #666;
  text-align: center;
  margin-bottom: 20rpx;
}

/* 空状态 */
.empty {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  background-color: #f5f5f5;
  padding: 40rpx;
}

.empty__image {
  width: 200rpx;
  height: 200rpx;
  margin-bottom: 32rpx;
}

.empty__text {
  font-size: 28rpx;
  color: #999;
}

/* 订单列表 */
.orders {
  padding: 16rpx 0;
}

.order-item {
  background-color: #fff;
  border-radius: 12rpx;
  margin: 0 0 24rpx 0;
  overflow: hidden;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.1);
  border: 1rpx solid #f0f0f0;
  cursor: pointer;
  transition: all 0.3s ease;
}

.order-item:active {
  transform: scale(0.98);
  box-shadow: 0 2rpx 6rpx rgba(0, 0, 0, 0.1);
}

.order-item__header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 8rpx 24rpx;
  background-color: #fff;
}

.order-item__shop {
  font-size: 26rpx;
  font-weight: 500;
  color: #333;
}

.order-item__status {
  font-size: 24rpx;
  color: #ff6b6b;
  font-weight: 500;
}

.order-item__content {
  padding: 8rpx 24rpx;
}

.order-item__product {
  display: flex;
  align-items: center;
  margin-bottom: 8rpx;
}

.order-item__product:last-child {
  margin-bottom: 0;
}

.order-item__image {
  width: 120rpx;
  height: 120rpx;
  border-radius: 8rpx;
  margin-right: 16rpx;
  background-color: #f8f8f8;
}

.order-item__info {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.order-item__name {
  font-size: 26rpx;
  color: #333;
  line-height: 1.4;
  margin-bottom: 8rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
}

.order-item__spec {
  font-size: 22rpx;
  color: #999;
  margin-bottom: 12rpx;
}

.order-item__bottom {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.order-item__price {
  font-size: 28rpx;
  font-weight: 600;
  color: #000;
}

.order-item__quantity {
  font-size: 24rpx;
  color: #999;
}

.order-item__divider {
  display: none;
}

.order-item__footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 4rpx 24rpx 16rpx 30rpx;
  background-color: #fff;
  flex-wrap: wrap;
  gap: 16rpx;
  margin-top: -8rpx;
}

.order-item__total {
  display: flex;
  flex-direction: column;
  font-size: 22rpx;
  color: #666;
  flex-shrink: 1;
  min-width: 0;
  flex: 1;
}

.order-item__total-price {
  font-size: 26rpx;
  font-weight: 600;
  color: #000;
  margin-top: 4rpx;
}

.order-item__actions {
  display: flex;
  gap: 12rpx;
  align-items: flex-end;
  justify-content: flex-end;
  flex-shrink: 0;
  min-width: 0;
}

.order-item__btn {
  padding: 8rpx 24rpx;
  background-color: #f5f5f5;
  color: #333;
  border: none;
  border-radius: 16rpx;
  font-size: 22rpx;
  text-align: center;
  white-space: nowrap;
  display: inline-block;
  max-width: 180rpx;
  width: auto;
}

.order-item__btn--primary {
  background-color: #000;
  color: #fff;
  white-space: nowrap;
  display: inline-block;
  max-width: 180rpx;
  width: auto;
}

/* 按钮样式 */
.btn {
  padding: 16rpx 32rpx;
  border-radius: 8rpx;
  font-size: 24rpx;
  font-weight: 500;
}

.btn-primary {
  background-color: #000;
  color: #fff;
  border: none;
}

.btn-secondary {
  background-color: #f5f5f5;
  color: #333;
  border: 1rpx solid #e0e0e0;
}



/* 物流弹窗 */
.logistics-modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 1000;
  display: flex;
  align-items: flex-end;
  justify-content: center;
}

.logistics-modal__mask {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(0, 0, 0, 0.5);
}

.logistics-modal__content {
  position: relative;
  width: 100%;
  max-height: 75vh;
  background-color: #fff;
  border-radius: 32rpx 32rpx 0 0;
  overflow: hidden;
  animation: slideUp 0.3s ease-out;
  display: flex;
  flex-direction: column;
  padding-bottom: env(safe-area-inset-bottom);
}

@keyframes slideUp {
  from {
    transform: translateY(100%);
  }
  to {
    transform: translateY(0);
  }
}

.logistics-modal__header {
  padding: 24rpx;
  border-bottom: 1rpx solid #f0f0f0;
  text-align: center;
}

.logistics-modal__title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
}

.logistics-modal__info {
  padding: 24rpx;
  background-color: #fafafa;
}

.logistics-modal__info-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 12rpx 0;
}

.logistics-modal__info-label {
  font-size: 26rpx;
  color: #999;
}

.logistics-modal__info-value {
  font-size: 26rpx;
  color: #333;
  font-weight: 500;
}

.logistics-modal__track {
  padding: 24rpx;
  flex: 1;
  overflow-y: auto;
}

.logistics-modal__track-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 20rpx;
}

.logistics-modal__track-list {
  padding-left: 20rpx;
}

.logistics-modal__track-item {
  display: flex;
  padding: 16rpx 0;
  position: relative;
}

.logistics-modal__track-dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  background-color: #d9d9d9;
  margin-right: 20rpx;
  flex-shrink: 0;
  margin-top: 4rpx;
}

.logistics-modal__track-line {
  position: absolute;
  left: 7rpx;
  top: 36rpx;
  bottom: 0;
  width: 2rpx;
  background-color: #d9d9d9;
}

.logistics-modal__track-content {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.logistics-modal__track-text {
  font-size: 26rpx;
  color: #333;
  line-height: 1.5;
}

.logistics-modal__track-time {
  font-size: 22rpx;
  color: #999;
  margin-top: 8rpx;
}

/* 动画 */
@keyframes spin {
  to {
    transform: rotate(360deg);
  }
}

/* 订单列表滚动容器 */
.order-list {
  flex: 1;
  overflow: hidden;
  display: flex;
  flex-direction: column;
}

.orders {
  flex: 1;
  height: calc(100vh - 280rpx);
}

/* 加载更多 */
.loading-more {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 20rpx 0;
}

.loading-more__spinner {
  width: 32rpx;
  height: 32rpx;
  border: 2rpx solid #ddd;
  border-top-color: #000;
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
  margin-right: 12rpx;
}

.loading-more__text {
  font-size: 24rpx;
  color: #999;
}

/* 没有更多 */
.no-more {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 20rpx 0;
}

.no-more__text {
  font-size: 24rpx;
  color: #999;
}