.page-root {
  width: 100%;
  height: 100%;
  background-color: #f5f5f5;
  overflow: hidden;
  display: flex;
  flex-direction: column;
}

.order-list {
  flex: 1;
  overflow-y: auto;
}

/* 加载状态 */
.loading {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  background-color: #f5f5f5;
}

.loading__spinner {
  width: 60rpx;
  height: 60rpx;
  border-radius: 50%;
  border: 6rpx solid #e0e0e0;
  border-top-color: #000;
  animation: spin 1s linear infinite;
  margin-bottom: 20rpx;
}

.loading__text {
  font-size: 24rpx;
  color: #666;
}

/* 错误状态 */
.error {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  background-color: #f5f5f5;
  padding: 40rpx;
}

.error__text {
  font-size: 24rpx;
  color: #666;
  text-align: center;
  margin-bottom: 20rpx;
}

/* 空状态 */
.empty {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  background-color: #f5f5f5;
  padding: 40rpx;
}

.empty__text {
  font-size: 28rpx;
  color: #999;
  margin-bottom: 32rpx;
}

/* 订单列表 */
.orders {
  padding: 16rpx;
}

.order-item {
  background-color: #fff;
  border-radius: 12rpx;
  padding: 24rpx;
  margin-bottom: 16rpx;
}

.order-item__header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
  padding-bottom: 16rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.order-item__order-number {
  font-size: 24rpx;
  color: #666;
}

.order-item__status {
  font-size: 24rpx;
  color: #000;
  font-weight: 500;
}

.order-item__content {
  display: flex;
  align-items: center;
  margin-bottom: 16rpx;
  padding-bottom: 16rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.order-item__image {
  width: 120rpx;
  height: 120rpx;
  border-radius: 8rpx;
  margin-right: 16rpx;
  background-color: #f8f8f8;
}

.order-item__info {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.order-item__name {
  font-size: 24rpx;
  color: #333;
  line-height: 1.4;
  margin-bottom: 12rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
}

.order-item__bottom {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.order-item__price {
  font-size: 26rpx;
  font-weight: 600;
  color: #000;
}

.order-item__quantity {
  font-size: 24rpx;
  color: #999;
}

.order-item__footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-top: 16rpx;
}

.order-item__total {
  font-size: 24rpx;
  color: #333;
}

.order-item__btn {
  padding: 8rpx 24rpx;
  background-color: #f5f5f5;
  color: #333;
  border: none;
  border-radius: 16rpx;
  font-size: 22rpx;
}

/* 按钮样式 */
.btn {
  padding: 16rpx 32rpx;
  border-radius: 8rpx;
  font-size: 24rpx;
  font-weight: 500;
}

.btn-primary {
  background-color: #000;
  color: #fff;
  border: none;
}

.btn-secondary {
  background-color: #f5f5f5;
  color: #333;
  border: 1rpx solid #e0e0e0;
}

/* 动画 */
@keyframes spin {
  to {
    transform: rotate(360deg);
  }
}