.payment-success {
  font-family: 'PingFang SC', 'Helvetica Neue', Arial, sans-serif;
  background-color: #f8f8f8;
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: flex-start;
  padding: 80rpx 32rpx 0;
  position: relative;
}

.payment-success__content {
  text-align: center;
  margin-bottom: 80rpx;
  z-index: 1;
  padding-top: 40rpx;
  width: 100%;
  max-width: 100%;
}

.payment-success__icon {
  width: 160rpx;
  height: 160rpx;
  margin: 0 auto 40rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, #a8edea 0%, #fed6e3 100%);
  border-radius: 50%;
  box-shadow: 0 8rpx 32rpx rgba(168, 237, 234, 0.4);
  animation: pulse 2s ease-in-out infinite;
}

@keyframes pulse {
  0% {
    transform: scale(1);
    box-shadow: 0 8rpx 32rpx rgba(168, 237, 234, 0.4);
  }
  50% {
    transform: scale(1.05);
    box-shadow: 0 12rpx 40rpx rgba(168, 237, 234, 0.6);
  }
  100% {
    transform: scale(1);
    box-shadow: 0 8rpx 32rpx rgba(168, 237, 234, 0.4);
  }
}

.payment-success__icon-image {
  width: 96rpx;
  height: 96rpx;
  transform: scale(1.1);
}

.payment-success__title {
  font-size: 40rpx;
  font-weight: 700;
  color: #333;
  margin-bottom: 16rpx;
  letter-spacing: 2rpx;
  line-height: 1.2;
  display: block;
}

.payment-success__message {
  font-size: 28rpx;
  color: #666;
  line-height: 40rpx;
  max-width: 100%;
  margin: 0 auto;
  letter-spacing: 1rpx;
  display: block;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.payment-success__buttons {
  width: 100%;
  display: flex;
  flex-direction: column;
  gap: 24rpx;
  z-index: 1;
  padding-bottom: 40rpx;
}

.payment-success__button {
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  border-radius: 44rpx;
  font-size: 32rpx;
  font-weight: 600;
  border: none;
  outline: none;
  -webkit-appearance: none;
  appearance: none;
  transition: all 0.3s ease;
  position: relative;
  display: flex;
  align-items: center;
  justify-content: center;
  white-space: nowrap;
  text-overflow: ellipsis;
  overflow: hidden;
}

.payment-success__button--primary {
  background-color: #000;
  color: #fff;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.1);
}

.payment-success__button--primary:active {
  transform: scale(0.98);
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.2);
}

.payment-success__button--secondary {
  background-color: #fff;
  color: #333;
  border: 2rpx solid #e0e0e0;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
}

.payment-success__button--secondary:active {
  transform: scale(0.98);
  background-color: #f8f8f8;
}

/* 响应式设计 */
@media (max-width: 375px) {
  .payment-success {
    padding: 0 24rpx;
  }
  
  .payment-success__icon {
    width: 140rpx;
    height: 140rpx;
  }
  
  .payment-success__icon-image {
    width: 84rpx;
    height: 84rpx;
  }
  
  .payment-success__title {
    font-size: 36rpx;
  }
  
  .payment-success__message {
    font-size: 26rpx;
  }
  
  .payment-success__button {
    height: 80rpx;
    line-height: 80rpx;
    font-size: 30rpx;
  }
}

/* 横屏模式 */
@media (orientation: landscape) {
  .payment-success__buttons {
    flex-direction: row;
    max-width: 600rpx;
  }
  
  .payment-success__button {
    flex: 1;
    margin: 0 16rpx;
  }
}