/* pages/admin/user-manage/index.wxss */
.user-manage {
  background-color: #f5f5f5;
  min-height: 100vh;
}

/* 页面头部 */
.admin-header {
  background-color: #1989fa;
  color: white;
  padding: 45rpx 30rpx 30rpx;
  text-align: center;
}

.admin-header__title {
  font-size: 32rpx;
  font-weight: bold;
}

/* 用户列表 */
.user-list {
  padding: 20rpx 30rpx;
}

.user-item {
  background-color: white;
  border-radius: 16rpx;
  padding: 20rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.08);
  display: flex;
  align-items: center;
}

.user-item__avatar {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  margin-right: 20rpx;
}

.user-item__info {
  flex: 1;
}

.user-item__name {
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 10rpx;
  display: block;
}

.user-item__created {
  font-size: 24rpx;
  color: #999;
  display: block;
}

.user-item__action-button {
  background-color: #1989fa;
  color: white;
  border: none;
  border-radius: 20rpx;
  padding: 10rpx 20rpx;
  font-size: 24rpx;
  min-width: 120rpx;
}

/* 空状态 */
.empty-state {
  background-color: white;
  border-radius: 16rpx;
  padding: 80rpx 30rpx;
  text-align: center;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.08);
}

.empty-state__text {
  font-size: 28rpx;
  color: #999;
}

/* 加载状态 */
.loading-state {
  padding: 40rpx 0;
  text-align: center;
}

.loading-state__text {
  font-size: 24rpx;
  color: #999;
}
