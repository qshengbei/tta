.order-detail {
  min-height: 100vh;
  background-color: #fff;
}

.order-detail__header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 32rpx;
  background-color: #fff;
  border-bottom: 1rpx solid #f0f0f0;
}

.order-detail__title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
}

.order-detail__back {
  font-size: 48rpx;
  color: #999;
  line-height: 1;
  padding: 0 16rpx;
}

.order-detail__loading {
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
  height: 400rpx;
  background-color: #fff;
  margin: 20rpx;
  border-radius: 12rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
}

.order-detail__loading-spinner {
  width: 60rpx;
  height: 60rpx;
  border-radius: 50%;
  border: 6rpx solid #e0e0e0;
  border-top-color: #000;
  animation: spin 1s linear infinite;
  margin-bottom: 24rpx;
}

@keyframes spin {
  to {
    transform: rotate(360deg);
  }
}

.order-detail__loading-text {
  font-size: 28rpx;
  color: #999;
}

.order-detail__error {
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
  height: 400rpx;
  background-color: #fff;
  margin: 20rpx;
  border-radius: 12rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
}

.order-detail__error-text {
  font-size: 28rpx;
  color: #ff4d4f;
  margin-bottom: 32rpx;
}

.order-detail__error-button {
  width: 200rpx;
  height: 80rpx;
  background-color: #000;
  color: #fff;
  border-radius: 40rpx;
  font-size: 28rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.order-detail__error-button::after {
  border: none;
}

.order-detail__content {
  padding: 0;
  width: 100%;
  box-sizing: border-box;
}

.order-detail__section {
  background-color: #fff;
  border-radius: 0;
  box-shadow: none;
  margin-bottom: 0;
  padding: 16rpx 32rpx;
  border-bottom: none;
}

/* 订单操作按钮 */
.order-detail__footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 4rpx 24rpx 16rpx 30rpx;
  background-color: #fff;
  flex-wrap: wrap;
  gap: 16rpx;
  margin-top: -8rpx;
}

/* 固定底部样式 */
.order-detail__footer.fixed-bottom {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  z-index: 100;
  padding: 16rpx 24rpx 32rpx 30rpx; /* 增加底部安全距离 */
  box-shadow: 0 -2rpx 10rpx rgba(0, 0, 0, 0.05); /* 添加阴影效果 */
}

/* 为内容区域添加底部间距，避免被固定按钮遮挡 */
.order-detail__content {
  padding-bottom: 120rpx; /* 为固定底部按钮留出空间 */
}

.order-detail__total {
  display: flex;
  flex-direction: column;
  font-size: 22rpx;
  color: #666;
  flex-shrink: 1;
  min-width: 0;
  flex: 1;
}

.order-detail__actions {
  display: flex;
  gap: 12rpx;
  align-items: center;
  justify-content: flex-end;
  flex-shrink: 0;
  min-width: 0;
}

.order-detail__btn {
  padding: 8rpx 24rpx;
  background-color: #f5f5f5;
  color: #333;
  border: none;
  border-radius: 16rpx;
  font-size: 22rpx;
  text-align: center;
  white-space: nowrap;
  display: inline-block;
  max-width: 180rpx;
  width: auto;
}

.order-detail__btn--primary {
  background-color: #000;
  color: #fff;
  white-space: nowrap;
  display: inline-block;
  max-width: 180rpx;
  width: auto;
}

.order-detail__section-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 24rpx;
}

.order-detail__info-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.order-detail__info-label {
  font-size: 24rpx;
  color: #666;
}

.order-detail__info-value {
  font-size: 24rpx;
  color: #333;
}

.order-status-container {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
}

.order-countdown {
  font-size: 20rpx;
  color: #ff6b6b;
  margin-top: 4rpx;
}

.order-detail__product-item {
  display: flex;
  align-items: center;
  padding: 12rpx 0;
  border-bottom: none;
}

.order-detail__product-item:last-child {
  border-bottom: none;
}

.order-detail__product-image {
  width: 120rpx;
  height: 120rpx;
  border-radius: 8rpx;
  margin-right: 24rpx;
}

.order-detail__product-info {
  flex: 1;
  min-width: 0;
}

.order-detail__product-name {
  font-size: 24rpx;
  color: #333;
  line-height: 1.2;
  margin-bottom: 4rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
}

.order-detail__product-tags {
  display: flex;
  flex-wrap: wrap;
  align-items: flex-start;
  margin-bottom: 0;
}

.order-detail__product-tag {
  font-size: 20rpx;
  color: #52c41a;
  line-height: 20rpx;
  margin-right: 8rpx;
  padding: 0;
  background-color: transparent;
  border-radius: 0;
}

.order-detail__product-tag--after-sales {
  color: #faad14;
  background-color: transparent;
  padding: 0;
  border: none;
  border-radius: 0;
  height: 50rpx;
}

.order-detail__product-bottom {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-top: 4rpx;
}

.order-detail__product-price {
  font-size: 24rpx;
  font-weight: 600;
  color: #000;
}

.order-detail__product-actions {
  display: flex;
  gap: 16rpx;
}

.order-detail__product-btn {
  font-size: 20rpx;
  padding: 0 16rpx;
  height: 44rpx;
  background-color: #f5f5f5;
  color: #333;
  border: none;
  border-radius: 16rpx;
  line-height: 44rpx;
  white-space: nowrap;
  max-width: 120rpx;
  width: auto;
  display: inline-flex;
  align-items: center;
  justify-content: center;
}

.order-detail__product-btn::after {
  border: none;
}

.order-detail__product-btn--history {
  background-color: #e8e8e8;
  color: #666;
}

.order-detail__product-quantity {
  font-size: 24rpx;
  color: #999;
  margin-left: 24rpx;
}

.order-detail__amount-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.order-detail__amount-label {
  font-size: 24rpx;
  color: #666;
}

.order-detail__amount-value {
  font-size: 24rpx;
  color: #333;
}

.order-detail__amount-item--total {
  margin-top: 16rpx;
  padding-top: 16rpx;
  border-top: 1rpx solid #f0f0f0;
}

.order-detail__amount-value--total {
  font-size: 28rpx;
  font-weight: 600;
  color: #000;
}

/* 地址操作按钮 */
.address-actions {
  display: flex;
  gap: 16rpx;
  align-items: center;
  margin-left: 16rpx;
}

.address-action-icon {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 40rpx;
  height: 40rpx;
  cursor: pointer;
  transition: all 0.3s ease;
}

.order-detail__message-item {
  margin-top: 12rpx;
  padding: 12rpx;
  background-color: #f9f9f9;
  border-radius: 4rpx;
  display: flex;
  align-items: center;
  border-left: 4rpx solid #e0e0e0;
}

.order-detail__message-label {
  font-size: 22rpx;
  color: #999;
  margin-right: 12rpx;
  min-width: 50rpx;
}

.order-detail__message-value {
  font-size: 22rpx;
  color: #666;
  flex: 1;
  word-break: break-word;
}

.address-action-icon-img {
  width: 30rpx;
  height: 30rpx;
}

.address-action-icon:hover {
  transform: scale(1.1);
}

.address-action-icon:active {
  transform: scale(0.95);
}

/* 同城配送地图信息 */
.local-delivery-info__map {
  margin-top: 8rpx;
  padding: 16rpx;
  background-color: #f8f8f8;
  border-radius: 8rpx;
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.local-delivery-info__legend {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  margin-bottom: 8rpx;
}

.local-delivery-info__legend-item {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.local-delivery-info__legend-color {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
}

.local-delivery-info__legend-text {
  font-size: 20rpx;
  color: #666;
  line-height: 0rpx;
}

.local-delivery-info__map-container {
  margin-top: 8rpx;
  border-radius: 8rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.1);
  position: relative;
}

.local-delivery-info__map-view {
  width: 100%;
  height: 300rpx;
}

.map-controls {
  position: absolute;
  bottom: 16rpx;
  right: 16rpx;
  display: flex;
  flex-direction: column;
  gap: 12rpx;
  z-index: 10;
}

.map-controls__button {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  background-color: rgba(255, 255, 255, 0.9);
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.15);
  cursor: pointer;
  transition: all 0.3s ease;
}

.map-controls__button:hover {
  background-color: rgba(255, 255, 255, 1);
  transform: scale(1.05);
}

.map-controls__button:active {
  transform: scale(0.95);
}

.map-controls__button-icon {
  width: 32rpx;
  height: 32rpx;
}

.local-delivery-info__distance {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.local-delivery-info__distance-text {
  font-size: 24rpx;
  color: #333;
}

/* 物流信息弹窗 */
.logistics-modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 9999;
  display: flex;
  align-items: flex-end;
  justify-content: center;
}

.logistics-modal__mask {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(0, 0, 0, 0.5);
}

.logistics-modal__content {
  position: relative;
  width: 100%;
  max-height: 75vh;
  background-color: #fff;
  border-radius: 32rpx 32rpx 0 0;
  overflow: hidden;
  animation: slideUp 0.3s ease-out;
  display: flex;
  flex-direction: column;
  padding-bottom: env(safe-area-inset-bottom);
}

@keyframes slideUp {
  from {
    transform: translateY(100%);
  }
  to {
    transform: translateY(0);
  }
}

.logistics-modal__header {
  padding: 24rpx;
  border-bottom: 1rpx solid #f0f0f0;
  text-align: center;
}

.logistics-modal__title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
}

.logistics-modal__info {
  padding: 24rpx;
  background-color: #fafafa;
}

.logistics-modal__info-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 12rpx 0;
}

.logistics-modal__info-label {
  font-size: 26rpx;
  color: #999;
}

.logistics-modal__info-value {
  font-size: 26rpx;
  color: #333;
  font-weight: 500;
}

.logistics-modal__track {
  padding: 24rpx;
  flex: 1;
  overflow-y: auto;
}

.logistics-modal__track-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 20rpx;
}

.logistics-modal__track-list {
  padding-left: 20rpx;
}

.logistics-modal__track-item {
  display: flex;
  padding: 16rpx 0;
  position: relative;
}

.logistics-modal__track-dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  background-color: #d9d9d9;
  margin-right: 20rpx;
  flex-shrink: 0;
  margin-top: 4rpx;
}

.logistics-modal__track-line {
  position: absolute;
  left: 7rpx;
  top: 36rpx;
  bottom: 0;
  width: 2rpx;
  background-color: #d9d9d9;
}

.logistics-modal__track-content {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.logistics-modal__track-text {
  font-size: 26rpx;
  color: #333;
  line-height: 1.5;
}

.logistics-modal__track-time {
  font-size: 22rpx;
  color: #999;
  margin-top: 8rpx;
}

.logistics-modal__map-section {
  margin-bottom: 24rpx;
}

.logistics-modal__map-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 16rpx;
  padding-left: 8rpx;
  border-left: 4rpx solid #1890ff;
}

.logistics-modal__map-container {
  width: 100%;
  height: 400rpx;
  margin-bottom: 16rpx;
  border-radius: 12rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.1);
}

.logistics-modal__map {
  width: 100%;
  height: 100%;
}

.logistics-modal__map-buttons {
  display: flex;
  justify-content: flex-end;
}

.logistics-modal__map-btn {
  margin: 0 8rpx;
  padding: 12rpx 24rpx;
  font-size: 26rpx;
  border-radius: 8rpx;
  border: 1rpx solid #d9d9d9;
  background: #fff;
  color: #333;
}

.logistics-modal__map-btn::after {
  border: none;
}

/* 售后类型选择弹窗 */
.after-sales-modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 9999;
}

.after-sales-modal__mask {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
}

.after-sales-modal__content {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  background: #fff;
  border-radius: 20rpx 20rpx 0 0;
  max-height: 70vh;
  display: flex;
  flex-direction: column;
}

.after-sales-modal__header {
  display: flex;
  justify-content: center;
  align-items: center;
  padding: 32rpx;
  border-bottom: 1rpx solid #f0f0f0;
  flex-shrink: 0;
  min-height: 96rpx;
}

.after-sales-modal__title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
  line-height: 1.6;
}

.after-sales-modal__close {
  width: 48rpx;
  height: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
  color: #999;
}

.after-sales-modal__body {
  flex: 1;
  overflow-y: auto;
  padding: 24rpx 32rpx;
}

/* 商品信息 */
.after-sales-modal__product {
  display: flex;
  align-items: flex-start;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
}

.after-sales-modal__product-image-wrap {
  position: relative;
  margin-right: 20rpx;
}

.after-sales-modal__product-image {
  width: 140rpx;
  height: 140rpx;
  border-radius: 8rpx;
  background: #f5f5f5;
}

.after-sales-modal__product-sign {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  height: 44rpx;
  line-height: 44rpx;
  text-align: center;
  font-size: 20rpx;
  color: #fff;
  background: rgba(0, 0, 0, 0.55);
  border-radius: 0 0 8rpx 8rpx;
}

.after-sales-modal__product-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  padding-top: 8rpx;
  justify-content: center;
}

.after-sales-modal__product-name {
  font-size: 26rpx;
  color: #333;
  line-height: 1.5;
  margin-bottom: 8rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
}

.after-sales-modal__product-spec {
  font-size: 22rpx;
  color: #999;
  margin-bottom: 8rpx;
}

.after-sales-modal__product-price {
  font-size: 26rpx;
  font-weight: 600;
  color: #333;
}

.after-sales-modal__product-count {
  font-size: 24rpx;
  color: #999;
  flex-shrink: 0;
  align-self: center;
}

/* 服务标签 */
.after-sales-modal__service {
  display: flex;
  align-items: center;
  padding: 20rpx 0;
}

.after-sales-modal__service-icon {
  font-size: 24rpx;
  margin-right: 8rpx;
}

.after-sales-modal__service-text {
  font-size: 24rpx;
  color: #999;
}

/* 售后类型列表 */
.after-sales-modal__type-list {
  padding-top: 8rpx;
}

.after-sales-modal__type-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 28rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
}

.after-sales-modal__type-item--active {
  background: #fff8f8;
}

.after-sales-modal__type-left {
  display: flex;
  align-items: center;
  flex: 1;
}

.after-sales-modal__type-icon {
  font-size: 36rpx;
  margin-right: 20rpx;
}

.after-sales-modal__type-info {
  flex: 1;
}

.after-sales-modal__type-name {
  font-size: 30rpx;
  font-weight: 500;
  color: #333;
  line-height: 1.3;
  display: block;
  margin-bottom: 4rpx;
}

.after-sales-modal__type-desc {
  font-size: 24rpx;
  color: #999;
  display: block;
}

.after-sales-modal__type-check {
  width: 40rpx;
  height: 40rpx;
  border: 2rpx solid #e0e0e0;
  border-radius: 50%;
  box-sizing: border-box;
  flex-shrink: 0;
}

.after-sales-modal__type-check--active {
  border: none;
  background: #ff4d4f;
  position: relative;
}

.after-sales-modal__type-check--active::after {
  content: '';
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%) rotate(-45deg);
  width: 16rpx;
  height: 10rpx;
  border-left: 3rpx solid #fff;
  border-bottom: 3rpx solid #fff;
}

/* 底部按钮 */
.after-sales-modal__footer {
  padding: 20rpx 32rpx 40rpx;
  border-top: 1rpx solid #f5f5f5;
  flex-shrink: 0;
}

.after-sales-modal__btn-next {
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  background: #ff4d4f;
  color: #fff;
  font-size: 32rpx;
  font-weight: 500;
  border-radius: 8rpx;
  border: none;
}

.after-sales-modal__btn-next::after {
  border: none;
}

.after-sales-modal__btn-next[disabled] {
  background: #e0e0e0;
  color: #999;
}

.after-sales-modal__back {
  width: 48rpx;
  height: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.after-sales-modal__back-icon {
  font-size: 40rpx;
  color: #333;
}

.after-sales-modal__footer-btns {
  display: flex;
  gap: 20rpx;
}

.after-sales-modal__btn-prev {
  flex: 1;
  height: 88rpx;
  line-height: 88rpx;
  background: #f5f5f5;
  color: #333;
  font-size: 32rpx;
  font-weight: 500;
  border-radius: 8rpx;
  border: none;
}

.after-sales-modal__btn-prev::after {
  border: none;
}

/* 售后原因 */
.after-sales-reason {
  width: 100%;
}

.after-sales-reason__time-tip {
  padding: 20rpx 24rpx;
  background: #fff7e6;
  border-radius: 8rpx;
  margin-bottom: 24rpx;
  text-align: center;
}

.after-sales-reason__time-tip text {
  font-size: 26rpx;
  color: #fa8c16;
}

.after-sales-reason__expired-tip {
  padding: 32rpx 24rpx;
  background: #fff1f0;
  border-radius: 8rpx;
  margin-bottom: 24rpx;
  text-align: center;
}

.after-sales-reason__expired-tip text {
  font-size: 28rpx;
  color: #ff4d4f;
  font-weight: 500;
}

.after-sales-reason__tabs {
  display: flex;
  background: #f5f5f5;
  border-radius: 8rpx;
  padding: 6rpx;
  margin-bottom: 24rpx;
}

.after-sales-reason__tab {
  flex: 1;
  text-align: center;
  padding: 20rpx 0;
  font-size: 28rpx;
  color: #666;
  border-radius: 6rpx;
  transition: all 0.3s;
}

.after-sales-reason__tab--active {
  background: #fff;
  color: #333;
