.order-detail {
  min-height: 100vh;
  background-color: #f8f8f8;
}

.order-detail__header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 32rpx;
  background-color: #fff;
  border-bottom: 1rpx solid #f0f0f0;
}

.order-detail__title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
}

.order-detail__back {
  font-size: 48rpx;
  color: #999;
  line-height: 1;
  padding: 0 16rpx;
}

.order-detail__loading {
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
  height: 400rpx;
  background-color: #fff;
  margin: 20rpx;
  border-radius: 12rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
}

.order-detail__loading-spinner {
  width: 60rpx;
  height: 60rpx;
  border-radius: 50%;
  border: 6rpx solid #e0e0e0;
  border-top-color: #000;
  animation: spin 1s linear infinite;
  margin-bottom: 24rpx;
}

@keyframes spin {
  to {
    transform: rotate(360deg);
  }
}

.order-detail__loading-text {
  font-size: 28rpx;
  color: #999;
}

.order-detail__error {
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
  height: 400rpx;
  background-color: #fff;
  margin: 20rpx;
  border-radius: 12rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
}

.order-detail__error-text {
  font-size: 28rpx;
  color: #ff4d4f;
  margin-bottom: 32rpx;
}

.order-detail__error-button {
  width: 200rpx;
  height: 80rpx;
  background-color: #000;
  color: #fff;
  border-radius: 40rpx;
  font-size: 28rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.order-detail__error-button::after {
  border: none;
}

.order-detail__content {
  padding: 20rpx;
}

.order-detail__section {
  background-color: #fff;
  border-radius: 12rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
  margin-bottom: 20rpx;
  padding: 32rpx;
}

.order-detail__section-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 24rpx;
}

.order-detail__info-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.order-detail__info-label {
  font-size: 24rpx;
  color: #666;
}

.order-detail__info-value {
  font-size: 24rpx;
  color: #333;
}

.order-detail__product-item {
  display: flex;
  align-items: center;
  padding: 24rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.order-detail__product-item:last-child {
  border-bottom: none;
}

.order-detail__product-image {
  width: 120rpx;
  height: 120rpx;
  border-radius: 8rpx;
  margin-right: 24rpx;
}

.order-detail__product-info {
  flex: 1;
  min-width: 0;
}

.order-detail__product-name {
  font-size: 24rpx;
  color: #333;
  margin-bottom: 12rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
}

.order-detail__product-price {
  font-size: 24rpx;
  font-weight: 600;
  color: #000;
}

.order-detail__product-quantity {
  font-size: 24rpx;
  color: #999;
  margin-left: 24rpx;
}

.order-detail__amount-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.order-detail__amount-label {
  font-size: 24rpx;
  color: #666;
}

.order-detail__amount-value {
  font-size: 24rpx;
  color: #333;
}

.order-detail__amount-item--total {
  margin-top: 16rpx;
  padding-top: 16rpx;
  border-top: 1rpx solid #f0f0f0;
}

.order-detail__amount-value--total {
  font-size: 28rpx;
  font-weight: 600;
  color: #000;
}
