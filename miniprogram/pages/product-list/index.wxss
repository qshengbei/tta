.product-list {
  width: 100%;
  height: 100%;
  background-color: #f5f5f5;
  padding-bottom: 20rpx;
}

.product-list__header {
  padding: 24rpx;
  background-color: #fff;
  border-bottom: 1rpx solid #f0f0f0;
}

.product-list__title {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
}

.product-list__content {
  padding: 16rpx;
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 16rpx;
}

.product-list__item {
  width: 100%;
}

.product-list__empty {
  grid-column: 1 / -1;
  padding: 100rpx 0;
  text-align: center;
}

.product-list__empty-text {
  font-size: 24rpx;
  color: #999;
}