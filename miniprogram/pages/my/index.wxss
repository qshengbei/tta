/* pages/my/index.wxss */

/* 页面容器 */
.my-page {
  min-height: 100vh;
  background-color: #f5f5f5;
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Helvetica, Arial, sans-serif;
}

/* 顶部个人信息区 */
.personal-info {
  position: relative;
  height: 200rpx;
  overflow: hidden;
  cursor: pointer;
  background: rgba(255, 255, 255, 0.6);
  backdrop-filter: blur(20px);
  -webkit-backdrop-filter: blur(20px);
  border-bottom: 1rpx solid rgba(255, 255, 255, 0.3);
}

.personal-info-content {
  display: flex;
  align-items: center;
  padding: 40rpx 30rpx;
}

.avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  border: 1rpx solid #e0e0e0;
}

.avatar-container {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  border: 1rpx solid #e0e0e0;
  background-color: #f5f5f5;
  display: flex;
  align-items: center;
  justify-content: center;
  text-align: center;
  padding: 10rpx;
}

.avatar-placeholder {
  font-size: 12rpx;
  color: #999999;
  line-height: 1.4;
}

.user-info {
  margin-left: 20rpx;
  flex: 1;
  display: flex;
  align-items: center;
}

.nickname {
  font-size: 28rpx;
  font-weight: 500;
  color: #333333;
}

.user-action {
  font-size: 22rpx;
  color: #999999;
}

.edit-icon {
  width: 32rpx;
  height: 32rpx;
  margin-left: 10rpx;
}

/* 订单管理区 */
.order-section {
  margin: 20rpx;
  background: rgba(255, 255, 255, 0.6);
  backdrop-filter: blur(20px);
  -webkit-backdrop-filter: blur(20px);
  border: 1rpx solid rgba(255, 255, 255, 0.3);
  border-radius: 12rpx;
  padding: 24rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
}

.order-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

.order-title {
  font-size: 26rpx;
  font-weight: 500;
  color: #333333;
}

.view-all {
  font-size: 22rpx;
  color: #999999;
  cursor: pointer;
}

.order-status {
  display: flex;
  justify-content: flex-start;
  width: 100%;
}

.order-status-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  cursor: pointer;
  padding: 10rpx 0;
  transition: all 0.3s ease;
  width: 20%;
}

.order-status-item:active {
  transform: translateY(2rpx);
}

.status-icon {
  width: 48rpx;
  height: 48rpx;
  margin-bottom: 8rpx;
}

.status-icon-container {
  position: relative;
  width: 48rpx;
  height: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.status-badge {
  position: absolute;
  top: -8rpx;
  right: -8rpx;
  background-color: #ff4d4f;
  color: #fff;
  font-size: 20rpx;
  font-weight: 600;
  min-width: 28rpx;
  height: 28rpx;
  border-radius: 14rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0 8rpx;
  box-shadow: 0 2rpx 4rpx rgba(0, 0, 0, 0.2);
}

.status-text {
  font-size: 20rpx;
  color: #666666;
  text-align: center;
}

/* 配送方式模块 */
.delivery-section {
  margin: 20rpx;
  background: rgba(255, 255, 255, 0.6);
  backdrop-filter: blur(20px);
  -webkit-backdrop-filter: blur(20px);
  border: 1rpx solid rgba(255, 255, 255, 0.3);
  border-radius: 12rpx;
  padding: 24rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
}

.delivery-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

.delivery-title {
  font-size: 26rpx;
  font-weight: 500;
  color: #333333;
}

.delivery-status {
  display: flex;
  justify-content: flex-start;
  width: 100%;
}

/* 上门自提状态 */
.delivery-status.pickup-status .delivery-status-item {
  width: 20%;
  margin-right: 0;
}

/* 同城配送状态 */
.delivery-status.local-status .delivery-status-item {
  width: 20%;
  margin-right: 0;
}

.delivery-status-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  cursor: pointer;
  padding: 10rpx 0;
  transition: all 0.3s ease;
  width: 20%;
}

.delivery-status-item:active {
  transform: translateY(2rpx);
}

/* 常用功能列表 */
.function-section {
  margin: 20rpx;
  background: rgba(255, 255, 255, 0.6);
  backdrop-filter: blur(20px);
  -webkit-backdrop-filter: blur(20px);
  border: 1rpx solid rgba(255, 255, 255, 0.3);
  border-radius: 12rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
  overflow: hidden;
}

.function-item {
  display: flex;
  align-items: center;
  padding: 28rpx 30rpx;
  border-bottom: 1rpx solid #f0f0f0;
  cursor: pointer;
  transition: all 0.3s ease;
}

.function-item:last-child {
  border-bottom: none;
}

.function-item:active {
  background-color: #f9f9f9;
}

.function-icon {
  width: 36rpx;
  height: 36rpx;
  margin-right: 20rpx;
}

.function-text {
  flex: 1;
  font-size: 26rpx;
  color: #333333;
}

.function-arrow {
  font-size: 24rpx;
  color: #999999;
}

/* 客服消息按钮 */
.customer-service-btn {
  background: transparent;
  border: none;
  outline: none;
  text-align: left;
  width: 100%;
  margin: 0;
  padding: 0;
}

.customer-service-btn::after {
  border: none;
}

/* 微信二维码弹窗 */
.modal-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 999;
}

.modal-content {
  background-color: #ffffff;
  border-radius: 12rpx;
  padding: 40rpx;
  width: 90%;
  max-width: 500rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.15);
}

.wechat-qr-code {
  max-width: 95%;
  max-height: 70vh;
  margin-bottom: 30rpx;
}

.wechat-qr-code-text {
  font-size: 24rpx;
  color: #333333;
  margin-bottom: 30rpx;
  text-align: center;
}

.wechat-qr-code-close {
  font-size: 24rpx;
  color: #3B82F6;
  margin-top: 10rpx;
  cursor: pointer;
  padding: 10rpx 20rpx;
  border-radius: 8rpx;
  background-color: #f5f5f5;
}

/* 响应式设计 */
@media (min-width: 750rpx) {
  .personal-info {
    height: 240rpx;
  }
  
  .personal-info-content {
    padding: 60rpx 40rpx;
  }
  
  .avatar {
    width: 100rpx;
    height: 100rpx;
  }
  
  .avatar-container {
    width: 100rpx;
    height: 100rpx;
  }
  
  .nickname {
    font-size: 32rpx;
  }
  
  .user-action {
    font-size: 24rpx;
  }
  
  .order-section,
  .function-section,
  .contact-section {
    margin: 30rpx;
    padding: 32rpx;
  }
  
  .order-title {
    font-size: 28rpx;
  }
  
  .view-all {
    font-size: 24rpx;
  }
  
  .status-icon {
    width: 56rpx;
    height: 56rpx;
  }
  
  .status-text {
    font-size: 22rpx;
  }
  
  .function-text,
  .contact-text {
    font-size: 28rpx;
  }
}

/* 管理员后台管理区域 */
.admin-section {
  margin: 20rpx;
  background: rgba(255, 255, 255, 0.6);
  backdrop-filter: blur(20px);
  -webkit-backdrop-filter: blur(20px);
  border: 1rpx solid rgba(255, 255, 255, 0.3);
  border-radius: 12rpx;
  padding: 24rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
}

.admin-section__title {
  font-size: 26rpx;
  font-weight: 500;
  color: #333333;
  margin-bottom: 24rpx;
}

.admin-section__items {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 10rpx;
}

.admin-section__item {
  display: flex;
  flex-direction: column;
  align-items: center;
  cursor: pointer;
  padding: 15rpx 0;
  transition: all 0.3s ease;
}

.admin-section__item:active {
  transform: translateY(2rpx);
  opacity: 0.8;
}

.admin-section__item-icon {
  width: 48rpx;
  height: 48rpx;
  margin-bottom: 8rpx;
}

.admin-section__item-text {
  font-size: 20rpx;
  color: #666666;
  text-align: center;
}

/* 横屏模式 */
@media (orientation: landscape) {
  .personal-info {
    height: 180rpx;
  }
  
  .personal-info-content {
    padding: 30rpx;
  }
  
  .avatar {
    width: 70rpx;
    height: 70rpx;
  }
  
  .avatar-container {
    width: 70rpx;
    height: 70rpx;
  }
  
  .nickname {
    font-size: 24rpx;
  }
  
  .user-action {
    font-size: 20rpx;
  }
  
  .order-section,
  .function-section,
  .contact-section,
  .admin-section {
    margin: 15rpx;
    padding: 20rpx;
  }
  
  .order-title,
  .admin-section__title {
    font-size: 24rpx;
  }
  
  .view-all {
    font-size: 20rpx;
  }
  
  .status-icon,
  .admin-section__item-icon {
    width: 40rpx;
    height: 40rpx;
  }
  
  .status-text,
  .admin-section__item-text {
    font-size: 18rpx;
  }
  
  .function-text,
  .contact-text {
    font-size: 24rpx;
  }
}

