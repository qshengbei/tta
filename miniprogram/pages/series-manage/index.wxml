<!-- pages/admin/series-manage/index.wxml -->
<view class="series-manage">
  <!-- 系列列表 -->
  <view class="series-list">
    <view wx:for="{{series}}" wx:key="_id" class="series-item">
      <image class="series-item__image" src="{{item.image || '../../../images/icons/default-series.png'}}" mode="aspectFill"></image>
      <view class="series-item__info">
        <text class="series-item__name">{{item.name}}</text>
        <text class="series-item__subtitle">{{item.subtitle}}</text>
      </view>
      <view class="series-item__actions">
        <button class="series-item__action-button status-button {{item.status === 'on' ? 'off-button' : 'on-button'}}" data-id="{{item._id}}" data-status="{{item.status}}" bindtap="toggleStatus">{{item.status === 'on' ? '下架' : '上架'}}</button>
        <button class="series-item__action-button edit-button" data-id="{{item._id}}" bindtap="editSeries">编辑</button>
        <button class="series-item__action-button delete-button" data-id="{{item._id}}" bindtap="deleteSeries">删除</button>
      </view>
    </view>
    
    <!-- 空状态 -->
    <view wx:if="{{series.length === 0 && !loading}}" class="empty-state">
      <text class="empty-state__text">暂无系列</text>
      <button class="empty-state__button" bindtap="addSeries">添加系列</button>
    </view>
    
    <!-- 加载状态 -->
    <view wx:if="{{loading}}" class="loading-state">
      <text class="loading-state__text">加载中...</text>
    </view>
  </view>
  
  <!-- 底部固定添加按钮 -->
  <button class="add-button fixed-bottom" bindtap="addSeries">添加系列</button>
</view>