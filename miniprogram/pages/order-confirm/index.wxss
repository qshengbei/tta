}

.express-rule-item__region {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 16rpx;
}

.express-rule-item__provinces {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
