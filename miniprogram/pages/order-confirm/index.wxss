}

.express-rule-item__province {
  font-size: 24rpx;
  color: #666;
  background-color: #e8e8e8;
  padding: 8rpx 16rpx;
  border-radius: 16rpx;
}

.express-rule-item__fee-free {
  display: flex;
  align-items: center;
  gap: 24rpx;
  flex-wrap: wrap;
}

