/* 快递计算规则弹窗 */
.express-rules-modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 9999;
  display: flex;
  flex-direction: column;
  justify-content: flex-end;
}

.express-rules-modal__overlay {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(0, 0, 0, 0.5);
}

.express-rules-modal__content {
  position: relative;
  background-color: #fff;
  border-radius: 32rpx 32rpx 0 0;
  padding: 32rpx;
  max-height: 80vh;
  display: flex;
  flex-direction: column;
  z-index: 1;
}

.express-rules-modal__title {
  font-size: 32rpx;
  font-weight: 600;
  text-align: center;
  margin-bottom: 32rpx;
  color: #333;
}

.express-rules-modal__scroll {
  flex: 1;
  overflow-y: auto;
  padding: 0 8rpx;
  -webkit-overflow-scrolling: touch;
}

.express-rules-modal__rules {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.express-rule-item {
