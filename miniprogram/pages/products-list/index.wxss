/* pages/products-list/index.wxss */

.products-list-page {
  min-height: 100vh;
  background-color: #f8f8f8;
}

/* 页面头部 */
.page-header {
  display: flex;
  align-items: center;
  height: 88rpx;
  background-color: #fff;
  border-bottom: 1rpx solid #f0f0f0;
  padding: 0 24rpx;
  position: relative;
}

.back-btn {
  width: 48rpx;
  height: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.back-icon {
  width: 24rpx;
  height: 24rpx;
}

.page-title {
  flex: 1;
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
  text-align: center;
  margin-left: -48rpx;
}

/* 排序选项 */
.sort-options {
  display: flex;
  background-color: #fff;
  padding: 0 32rpx;
  height: 72rpx;
  align-items: center;
  border-bottom: 1rpx solid #f0f0f0;
}

.sort-option {
  display: flex;
  align-items: center;
  margin-right: 48rpx;
  cursor: pointer;
}

.sort-text {
  font-size: 24rpx;
  color: #666;
  transition: all 0.3s ease;
}

.sort-option--active .sort-text {
  color: #000;
  font-weight: 500;
}

.sort-icon {
  width: 20rpx;
  height: 20rpx;
  margin-left: 8rpx;
}

/* 商品列表 */
.products-list {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 20rpx;
  padding: 20rpx;
}

.product-item {
  background-color: transparent;
  border-radius: 12rpx;
  overflow: hidden;
  transition: all 0.3s ease;
  display: flex;
  flex-direction: column;
}

.product-item:active {
  transform: translateY(2rpx);
}

.product-image-container {
  width: 100%;
  padding-top: 100%;
  position: relative;
  border-radius: 12rpx;
  overflow: hidden;
}

.product-image {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  object-fit: cover;
}

.product-info {
  padding: 12rpx 0 0 0;
  text-align: left;
}

.product-name {
  font-size: 24rpx;
  color: #333;
  margin-bottom: 4rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  max-width: 100%;
  display: block;
}

.product-price {
  font-size: 28rpx;
  font-weight: 600;
  color: #000;
  display: block;
  text-align: left;
}

/* 空状态 */
.empty-state {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 400rpx;
  background-color: #fff;
  margin: 20rpx;
  border-radius: 12rpx;
}

.empty-text {
  font-size: 24rpx;
  color: #999;
}

/* 响应式设计 */
@media (min-width: 750rpx) {
  .products-list {
    grid-template-columns: repeat(3, 1fr);
  }
}

/* 横屏模式 */
@media (orientation: landscape) {
  .page-header {
    height: 72rpx;
  }
  
  .sort-options {
    height: 60rpx;
  }
}