.search-result-page {
  padding-bottom: 60px;
}

.page-header {
  display: flex;
  align-items: center;
  padding: 16rpx;
  border-bottom: 1rpx solid #f0f0f0;
  background-color: #fff;
  position: sticky;
  top: 0;
  z-index: 100;
}

.back-btn {
  width: 48rpx;
  height: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.back-icon {
  width: 24rpx;
  height: 24rpx;
}

.search-bar {
  flex: 1;
  display: flex;
  align-items: center;
  background-color: #f5f5f5;
  border-radius: 24rpx;
  padding: 0 20rpx;
  margin: 0 16rpx;
  position: relative;
}

.search-input {
  flex: 1;
  height: 48rpx;
  font-size: 28rpx;
  color: #333;
  padding-right: 40rpx;
}

.search-icon {
  position: absolute;
  right: 20rpx;
  width: 24rpx;
  height: 24rpx;
  opacity: 0.5;
}

.cancel-btn {
  padding: 0 16rpx;
}

.cancel-text {
  font-size: 28rpx;
  color: #333;
}

.search-results {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 16rpx;
  padding: 16rpx;
}

.product-item {
  background-color: #fff;
  border-radius: 8rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.1);
  transition: transform 0.3s ease;
}

.product-item:active {
  transform: scale(0.98);
}

.product-image {
  width: 100%;
  height: 320rpx;
  object-fit: cover;
}

.product-info {
  padding: 12rpx;
}

.product-name {
  font-size: 28rpx;
  color: #333;
  margin-bottom: 8rpx;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.product-price {
  font-size: 32rpx;
  font-weight: 600;
  color: #ff4d4f;
}

.empty-state {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 400rpx;
  color: #999;
  font-size: 32rpx;
}

/* 响应式调整 */
@media screen and (min-width: 750rpx) {
  .search-results {
    grid-template-columns: repeat(3, 1fr);
  }
  
  .product-image {
    height: 400rpx;
  }
}