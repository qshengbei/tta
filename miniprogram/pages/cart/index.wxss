/* pages/cart/index.wxss */
.cart {
  min-height: 100vh;
  background-color: #f8f8f8;
  overflow: hidden;
}

/* 顶部固定搜索框 */
.cart__search-bar {
  display: flex;
  align-items: center;
  padding: 16rpx 32rpx;
  background-color: #fff;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
  position: sticky;
  top: 0;
  z-index: 999;
}

.cart__search-input-wrapper {
  flex: 1;
  display: flex;
  align-items: center;
  background-color: #f8f8f8;
  border-radius: 24rpx;
  padding: 0 20rpx;
  margin-right: 16rpx;
}

.cart__search-icon {
  width: 28rpx;
  height: 28rpx;
  margin-right: 16rpx;
  object-fit: contain;
}

.cart__search-input {
  flex: 1;
  height: 64rpx;
  font-size: 22rpx;
  color: #333;
  background-color: transparent;
  border: none;
}

.cart__search-input::placeholder {
  color: #999;
  font-size: 24rpx;
}

.cart__search-clear {
  width: 40rpx;
  height: 40rpx;
  border-radius: 20rpx;
  background-color: #e0e0e0;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  line-height: 40rpx;
  color: #666;
  cursor: pointer;
  margin-left: 12rpx;
  padding: 0;
  font-weight: bold;
  text-align: center;
}

.cart__action-btn {
  position: relative;
  width: 48rpx;
  height: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  background-color: #f8f8f8;
  transition: all 0.3s ease;
}

.cart__action-btn:active {
  background-color: #e8e8e8;
}

.cart__action-icon {
  width: 32rpx;
  height: 32rpx;
  object-fit: contain;
}

.cart__filter-badge {
  position: absolute;
  top: -8rpx;
  right: -8rpx;
  width: 24rpx;
  height: 24rpx;
  border-radius: 12rpx;
  background-color: #ff4d4f;
  color: #fff;
  font-size: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

/* 搜索历史和建议面板 */
.cart__search-suggestion-panel {
  background-color: #fff;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
  padding: 16rpx 32rpx;
  position: sticky;
  top: 96rpx;
  z-index: 998;
  max-height: 300rpx;
  overflow-y: auto;
}

/* 搜索历史 */
.cart__search-history {
  margin-bottom: 16rpx;
}

.cart__search-history-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12rpx;
}

.cart__search-history-title {
  font-size: 24rpx;
  color: #666;
  font-weight: 500;
}

.cart__search-history-clear {
  font-size: 22rpx;
  color: #999;
  cursor: pointer;
}

.cart__search-history-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.cart__search-history-tag {
  padding: 12rpx 20rpx;
  background-color: #f8f8f8;
  border-radius: 20rpx;
  font-size: 22rpx;
  color: #666;
  cursor: pointer;
  transition: all 0.3s ease;
}

.cart__search-history-tag:active {
  background-color: #e8e8e8;
}

/* 搜索建议 */
.cart__search-suggestions {
  margin-bottom: 16rpx;
}

.cart__search-suggestion-item {
  display: flex;
  align-items: center;
  padding: 12rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
  cursor: pointer;
}

.cart__search-suggestion-icon {
  width: 24rpx;
  height: 24rpx;
  margin-right: 16rpx;
  object-fit: contain;
}

.cart__search-suggestion-text {
  font-size: 26rpx;
  color: #333;
}

/* 搜索结果为空 */
.cart__search-empty {
  display: flex;
  justify-content: center;
  align-items: center;
  padding: 40rpx 0;
  color: #999;
  font-size: 26rpx;
}

/* 筛选面板 */
.cart__filter-modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(0, 0, 0, 0.5);
  z-index: 2000;
  display: flex;
  align-items: flex-start;
  justify-content: center;
  padding-top: 100rpx;
}

.cart__filter-container {
  width: 100%;
  background-color: #fff;
  border-bottom-left-radius: 24rpx;
  border-bottom-right-radius: 24rpx;
  padding: 32rpx 24rpx;
  max-height: 80vh;
  overflow-y: auto;
}

.cart__filter-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 32rpx;
  padding-bottom: 24rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.cart__filter-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
}

.cart__filter-reset {
  font-size: 24rpx;
  color: #000;
  cursor: pointer;
  padding: 8rpx 20rpx;
  border-radius: 20rpx;
  background-color: rgba(0, 0, 0, 0.1);
  transition: all 0.3s ease;
  border: 1rpx solid rgba(0, 0, 0, 0.3);
}

.cart__filter-reset:active {
  background-color: rgba(0, 0, 0, 0.2);
  transform: translateY(1rpx);
}

.cart__filter-section {
  margin-bottom: 32rpx;
}

.cart__filter-section-title {
  font-size: 26rpx;
  font-weight: 500;
  color: #333;
  margin-bottom: 16rpx;
}

.cart__filter-options {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

/* 库存状态选项样式 */
.cart__filter-section:nth-child(3) .cart__filter-options {
  display: flex;
  flex-direction: row;
  flex-wrap: wrap;
  gap: 12rpx;
}

.cart__filter-option {
  padding: 10rpx 20rpx;
  background-color: #f0f0f0;
  font-size: 22rpx;
  color: #666;
  border-radius: 20rpx;
  transition: all 0.3s ease;
  border: 2rpx solid transparent;
  white-space: nowrap;
  display: inline-block;
}

.cart__filter-option:active {
  background-color: #e0e0e0;
  transform: translateY(1rpx);
}

.cart__filter-option.cart__filter-option--active {
  background-color: #000 !important;
  color: #fff !important;
  border-color: #000 !important;
  font-weight: 500 !important;
}

.cart__filter-category-group {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.cart__filter-option {
  cursor: pointer;
  transition: all 0.3s ease;
}

.cart__filter-option-level1 {
  display: inline-block;
  align-self: flex-start;
  padding: 12rpx 24rpx;
  font-weight: 600;
  color: #333;
  font-size: 24rpx;
  border-radius: 24rpx;
}

.cart__filter-level2-container {
  margin-left: 24rpx;
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.cart__filter-option--active {
  background-color: #000 !important;
  color: #fff !important;
  border-color: #000 !important;
  font-weight: 500 !important;
}

.cart__filter-footer {
  margin-top: 40rpx;
  padding-top: 24rpx;
  border-top: 1rpx solid #f0f0f0;
}

.cart__filter-apply {
  width: 100%;
  height: 88rpx;
  background-color: #000;
  color: #fff;
  font-size: 28rpx;
  font-weight: 500;
  border-radius: 44rpx;
  border: none;
  display: flex;
  justify-content: center;
  align-items: center;
  transition: all 0.3s ease;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.3);
}

.cart__filter-apply:active {
  background-color: #333;
  transform: translateY(2rpx);
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.3);
}

/* 调整内容区域的padding-top，为顶部操作栏留出空间 */
.cart__content {
  padding-top: 20rpx;
}

.cart__content {
  padding: 20rpx;
  padding-bottom: 280rpx;
}

/* 加载状态 */
.cart__loading {
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
  height: 400rpx;
  background-color: #fff;
  border-radius: 12rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
  margin: 20rpx;
}

.cart__loading-spinner {
  width: 60rpx;
  height: 60rpx;
  border-radius: 50%;
  border: 6rpx solid #e0e0e0;
  border-top-color: #000;
  animation: spin 1s linear infinite;
  margin-bottom: 24rpx;
}

@keyframes spin {
  to {
    transform: rotate(360deg);
  }
}

.cart__loading-text {
  font-size: 28rpx;
  color: #999;
}

/* 选择框 */
.cart__checkbox {
  width: 40rpx;
  height: 40rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.3s ease;
}

.cart__checkbox-icon {
  width: 50rpx;
  height: 50rpx;
  object-fit: contain;
}

.cart__item-checkbox {
  margin-right: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  z-index: 2;
  pointer-events: auto;
}

/* 商品项 */
.cart__item {
  position: relative;
  margin-bottom: 20rpx;
  height: 200rpx;
  overflow: hidden;
  border-radius: 12rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
}

/* 点击区域 */
.cart__item-click-area {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  display: flex;
  padding: 20rpx;
  box-sizing: border-box;
  z-index: 1;
  pointer-events: auto;
  align-items: center;
}

/* 响应式设计 */
@media (min-width: 750rpx) {
  .cart__content {
    max-width: 750rpx;
    margin: 0 auto;
  }
  
  .cart__item {
    height: 240rpx;
  }
  
  .cart__item-image {
    width: 180rpx;
    height: 180rpx;
  }
  
  .cart__footer {
    height: 200rpx;
  }
}

/* 横屏模式优化 */
@media (orientation: landscape) {
  .cart__content {
    padding: 20rpx 40rpx;
  }
  
  .cart__item {
    height: 160rpx;
  }
  
  .cart__item-image {
    width: 120rpx;
    height: 120rpx;
  }
  
  .cart__footer {
    padding: 16rpx 40rpx;
    height: 160rpx;
  }
  
  .cart__footer-left {
    justify-content: center;
  }
  
  .cart__footer-right {
    flex-direction: row;
    align-items: center;
  }
  
  .cart__batch-action {
    margin-right: 20rpx;
  }
}

/* 触摸操作优化 */
.cart__item-content {
  touch-action: pan-y;
}

.cart__item-click-area {
  touch-action: manipulation;
}

.cart__item-content {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: #fff;
  transition: transform 0.3s ease;
  z-index: 1;
  will-change: transform;
}

/* 点击区域 */
.cart__item-click-area {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  display: flex;
  padding: 20rpx;
  box-sizing: border-box;
  z-index: 1;
  pointer-events: auto;
}

/* 商品图片容器 */
.cart__item-image-container {
  position: relative;
  margin-right: 20rpx;
  flex-shrink: 0;
}

/* 商品图片 */
.cart__item-image {
  width: 160rpx;
  height: 160rpx;
  border-radius: 8rpx;
  object-fit: cover;
  background-color: #f8f8f8;
}

/* 售罄覆盖层（整个卡片） */
.cart__item-sold-out-overlay {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(0, 0, 0, 0.3);
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 2;
  pointer-events: none;
}

.cart__item-sold-out-text {
  font-size: 36rpx;
  font-weight: 600;
  color: #fff;
  transform: rotate(-30deg);
  text-shadow: 0 2rpx 4rpx rgba(0, 0, 0, 0.3);
}

/* 商品信息 */
.cart__item-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  min-width: 0;
  height: 160rpx;
  justify-content: space-between;
}

.cart__item-name {
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
  margin-bottom: 16rpx;
  line-height: 40rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
}

.cart__item-bottom {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.cart__item-price {
  font-size: 32rpx;
  font-weight: 600;
  color: #000;
  flex-shrink: 0;
}

/* 数量选择器 */
.cart__item-quantity {
  display: flex;
  align-items: center;
  flex-shrink: 0;
}

.quantity-btn {
  width: 44rpx;
  height: 44rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  cursor: pointer;
  transition: all 0.3s ease;
  flex-shrink: 0;
}

.quantity-icon {
  width: 44rpx;
  height: 44rpx;
  object-fit: contain;
}

.quantity-btn:active {
  background-color: #f5f5f5;
}

.quantity-btn--minus {
  color: #999;
}

.quantity-btn--plus {
  color: #333;
}

.quantity-input {
  width: 90rpx;
  height: 44rpx;
  border: 2rpx solid #e0e0e0;
  border-radius: 8rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background-color: #f8f8f8;
  margin: 0 12rpx;
  flex-shrink: 0;
}

.quantity-input input {
  width: 100%;
  height: 100%;
  text-align: center;
  font-size: 24rpx;
  font-weight: 500;
  color: #333;
  background-color: transparent;
  border: none;
  padding: 0;
}

/* 删除按钮 */
.cart__item-delete {
  position: absolute;
  top: 0;
  right: 0;
  bottom: 0;
  width: 180rpx;
  background-color: #ff4d4f;
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 0;
  pointer-events: auto;
}

.cart__item-delete-text {
  font-size: 28rpx;
  color: #fff;
  font-weight: 500;
}

/* 空购物车状态 */
.cart__empty {
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
  height: 500rpx;
  background-color: #fff;
  border-radius: 12rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
  margin: 20rpx;
}

.cart__empty-image {
  width: 200rpx;
  height: 200rpx;
  margin-bottom: 32rpx;
  opacity: 0.6;
}

.cart__empty-text {
  font-size: 28rpx;
  color: #999;
  margin-bottom: 32rpx;
}

.cart__empty-btn {
  padding: 16rpx 64rpx;
  background-color: #000;
  color: #fff;
  font-size: 24rpx;
  font-weight: 500;
  border-radius: 40rpx;
  border: none;
}

/* 购物车底部 */
/* 全选按钮区域 */
.cart__select-section {
  position: fixed;
  bottom: 140rpx;
  left: 0;
  right: 0;
  background-color: #f8f8f8;
  border-top: none;
  padding: 16rpx 20rpx;
  z-index: 999;
}

.cart__select-all-btn {
  display: flex;
  align-items: center;
  justify-content: space-between;
  width: 100%;
  height: 60rpx; /* 设置固定高度 */
  padding: 0 20rpx; /* 调整内边距，使用固定高度 */
  background-color: #f8f8f8;
  border-radius: 8rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
  transition: all 0.3s ease;
}

.cart__select-all-btn:active {
  box-shadow: 0 1rpx 4rpx rgba(0, 0, 0, 0.05);
  transform: translateY(1rpx);
}

.cart__select-all-text {
  font-size: 28rpx;
  color: #333;
  margin-left: 12rpx;
  flex: 1;
}

.cart__batch-delete-btn {
  padding: 8rpx 16rpx;
  background-color: #f8f8f8;
  border-radius: 8rpx;
}

.cart__batch-delete-text {
  font-size: 24rpx;
  color: #666;
}

/* 购物车底部 */
.cart__footer {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  display: flex;
  justify-content: space-between;
  align-items: center;
  background-color: #fff;
  border-top: 1rpx solid #f0f0f0;
  box-shadow: 0 -2rpx 8rpx rgba(0, 0, 0, 0.05);
  padding: 20rpx 32rpx;
  height: 140rpx;
  box-sizing: border-box;
  z-index: 998;
}

.cart__total-section {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.cart__total {
  display: flex;
  align-items: center;
  margin-bottom: 4rpx;
}

.cart__total-label {
  font-size: 28rpx;
  color: #333;
  margin-right: 8rpx;
}

.cart__total-price {
  font-size: 36rpx;
  font-weight: 600;
  color: #000;
}

.cart__selected-count {
  font-size: 22rpx;
  color: #999;
}

.cart__checkout {
  width: 200rpx;
  height: 88rpx;
  background-color: #000;
  color: #fff;
  font-size: 28rpx;
  font-weight: 500;
  border-radius: 44rpx;
  display: flex;
  justify-content: center;
  align-items: center;
  border: none;
  padding: 0 24rpx;
  white-space: nowrap;
  text-overflow: ellipsis;
  overflow: hidden;
}

.cart__checkout:disabled {
  background-color: #e0e0e0;
  color: #999;
}

.cart__checkout:active {
  background-color: #333;
}

/* 覆盖默认按钮样式 */
wx-button:not([size=mini]) {
  width: auto !important;
  margin-left: 0 !important;
  margin-right: 0 !important;
}