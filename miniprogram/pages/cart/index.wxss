/* pages/cart/index.wxss */
.cart {
  min-height: 100vh;
  background-color: #f5f5f5;
}

.cart__header {
  padding: 20rpx;
  background-color: #fff;
  border-bottom: 1rpx solid #e5e5e5;
}

.cart__title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}

.cart__content {
  padding: 20rpx;
}

.cart__item {
  display: flex;
  background-color: #fff;
  border-radius: 12rpx;
  padding: 20rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
}

.cart__item-image {
  width: 160rpx;
  height: 160rpx;
  border-radius: 8rpx;
  margin-right: 20rpx;
}

.cart__item-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
}

.cart__item-name {
  font-size: 28rpx;
  color: #333;
  margin-bottom: 16rpx;
  line-height: 40rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
}

.cart__item-bottom {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.cart__item-price {
  font-size: 32rpx;
  font-weight: bold;
  color: #ff4d4f;
}

.cart__empty {
  display: flex;
  justify-content: center;
  align-items: center;
  height: 400rpx;
  background-color: #fff;
  border-radius: 12rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
}

.cart__empty-text {
  font-size: 28rpx;
  color: #999;
}

.cart__footer {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx;
  background-color: #fff;
  border-top: 1rpx solid #e5e5e5;
  box-shadow: 0 -2rpx 8rpx rgba(0, 0, 0, 0.05);
}

.cart__total {
  display: flex;
  align-items: center;
}

.cart__total-label {
  font-size: 28rpx;
  color: #333;
  margin-right: 8rpx;
}

.cart__total-price {
  font-size: 36rpx;
  font-weight: bold;
  color: #ff4d4f;
}

.cart__checkout {
  width: 200rpx;
  height: 72rpx;
  background-color: #ff4d4f;
  color: #fff;
  font-size: 28rpx;
  border-radius: 36rpx;
  display: flex;
  justify-content: center;
  align-items: center;
}
