/* pages/category/index.wxss */

.category-page {
  min-height: 100vh;
  background-color: #f8f8f8;
}


/* 标签切换 */
.tab-container {
  display: flex;
  background-color: #fff;
  border-bottom: 1rpx solid #f0f0f0;
}

.tab {
  flex: 1;
  display: flex;
  justify-content: center;
  align-items: center;
  height: 88rpx;
  position: relative;
}

.tab-text {
  font-size: 28rpx;
  color: #666;
  transition: all 0.3s ease;
}

.tab--active .tab-text {
  color: #000;
  font-weight: 600;
}

.tab--active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 40rpx;
  height: 4rpx;
  background-color: #000;
  border-radius: 2rpx;
}

/* 宝贝标签内容 */
.products-content {
  padding-bottom: 20rpx;
}

/* 排序选项 */
.sort-options {
  display: flex;
  background-color: #fff;
  padding: 0 32rpx;
  height: 72rpx;
  align-items: center;
  border-bottom: 1rpx solid #f0f0f0;
}

.sort-option {
  display: flex;
  align-items: center;
  margin-right: 48rpx;
  cursor: pointer;
}

.sort-text {
  font-size: 24rpx;
  color: #666;
  transition: all 0.3s ease;
}

.sort-option--active .sort-text {
  color: #000;
  font-weight: 500;
}

.sort-icon {
  width: 20rpx;
  height: 20rpx;
  margin-left: 8rpx;
}

/* 商品列表 */
.products-list {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 20rpx;
  padding: 20rpx;
  background-color: #f5f5f5;
}

/* 没有更多商品提示 */
.no-more {
  grid-column: 1 / -1;
  text-align: center;
  padding: 40rpx 0;
  color: #999;
  font-size: 28rpx;
  background-color: #f5f5f5;
}

.product-item {
  border-radius: 12rpx;
  overflow: hidden;
  transition: all 0.3s ease;
  display: flex;
  flex-direction: column;
}

.product-item:active {
  transform: translateY(2rpx);
}

.product-image-container {
  width: 100%;
  padding-top: 100%;
  position: relative;
  border-radius: 12rpx;
  overflow: hidden;
}

.product-image {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  object-fit: cover;
}

.product-info {
  padding: 12rpx 0 0 0;
  text-align: left;
}

.product-name {
  font-size: 24rpx;
  color: #333;
  margin-bottom: 4rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  max-width: 100%;
  display: block;
}

.product-price {
  font-size: 28rpx;
  font-weight: 600;
  color: #000;
  display: block;
  text-align: left;
}

/* 分类标签内容 */
.categories-content {
  height: calc(100vh - 160rpx);
}



.categories-container {
  display: flex;
  height: 100%;
}

/* 左侧分类导航 */
.categories-nav {
  width: 150rpx;
  background-color: #f8f8f8;
  overflow-y: auto;
}

.nav-item {
  display: flex;
  align-items: center;
  height: 80rpx;
  padding: 0 24rpx;
  cursor: pointer;
  position: relative;
  white-space: nowrap;
  overflow: hidden;
}

.nav-text {
  font-size: 24rpx;
  color: #666;
  transition: all 0.3s ease;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
  max-width: 100%;
}

.nav-item--active {
  background-color: #fff;
  font-weight: 500;
}

.nav-item--active .nav-text {
  color: #000;
}

.nav-item--active::before {
  content: '';
  position: absolute;
  left: 0;
  top: 50%;
  transform: translateY(-50%);
  width: 4rpx;
  height: 32rpx;
  background-color: #000;
  border-radius: 2rpx;
}

.nav-section-title {
  padding: 16rpx 24rpx;
  font-size: 20rpx;
  color: #999;
  font-weight: 500;
  border-top: 1rpx solid #f0f0f0;
  margin-top: 8rpx;
}

/* 右侧内容区域 */
.categories-content-area {
  flex: 1;
  background-color: #fff;
  overflow-y: auto;
  padding: 20rpx;
}

/* 系列内容 */
.series-content {
  width: 100%;
}

.series-header {
  text-align: center;
  margin-bottom: 20rpx;
  padding: 0 20rpx;
}

.series-title {
  font-size: 40rpx;
  font-weight: bold;
  color: #333;
  display: block;
  margin-bottom: 8rpx;
}

.series-subtitle {
  font-size: 24rpx;
  color: #999;
  display: block;
}

.series-image-container {
  position: relative;
  width: 100%;
  border-radius: 12rpx;
  overflow: hidden;
  margin-bottom: 20rpx;
  padding-top: 50%;
}

.series-image {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  object-fit: cover;
}

.series-products {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 16rpx;
}

.series-products .product-item {
  background-color: transparent;
  border-radius: 12rpx;
  overflow: hidden;
  transition: all 0.3s ease;
  display: flex;
  flex-direction: column;
}

.series-products .product-item:active {
  transform: translateY(2rpx);
}

.series-products .product-image {
  width: 100%;
  height: 300rpx;
  object-fit: cover;
  border-radius: 12rpx;
}

.series-products .product-info {
  padding: 12rpx 0 0 0;
  text-align: left;
}

.series-products .product-name {
  font-size: 24rpx;
  color: #333;
  margin-bottom: 4rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  max-width: 100%;
  display: block;
}

.series-products .product-price {
  font-size: 28rpx;
  font-weight: 600;
  color: #000;
  display: block;
  text-align: left;
}

/* 一级分类内容 */
.category-content {
  width: 100%;
}

.level1-category {
  position: relative;
  margin-bottom: 24rpx;
  border-radius: 12rpx;
  overflow: hidden;
  width: 100%;
  padding-top: 50%;
}

.level2-categories {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 16rpx;
}

.level2-category {
  position: relative;
  width: 100%;
  padding-top: 100%;
  border-radius: 12rpx;
  overflow: hidden;
}

.category-image {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  object-fit: cover;
}

.category-overlay {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(0, 0, 0, 0.3);
  display: flex;
  align-items: center;
  justify-content: center;
}

.category-text {
  font-size: 24rpx;
  font-weight: 500;
  color: #fff;
}

/* 默认内容 */
.default-content {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 100%;
}

.default-text {
  font-size: 24rpx;
  color: #999;
}


/* 响应式设计 */
@media (min-width: 750rpx) {
  .products-list {
    grid-template-columns: repeat(3, 1fr);
  }
  
  .series-products {
    grid-template-columns: repeat(3, 1fr);
  }
  
  .level2-categories {
    grid-template-columns: repeat(3, 1fr);
  }
}

/* 横屏模式 */
@media (orientation: landscape) {
  .categories-content {
    height: calc(100vh - 120rpx);
  }
  
  .series-image {
    height: 160rpx;
  }
  
  .category-image {
    height: 120rpx;
  }
}