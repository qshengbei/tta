/* pages/admin/product-publish/index.wxss */
page {
  background-color: var(--color-bg);
  padding: 0;
  margin: 0;
}

.product-publish {
  background-color: var(--color-bg);
  min-height: 100vh;
  padding-top: 0;
  margin-top: 0;
}

/* 商品表单 */
.product-form {
  padding: 0 14rpx;
  padding-bottom: 140rpx;
  margin: 0;
  position: relative;
  top: -35rpx;
}

/* 表单元素 */
form {
  margin: 0;
  padding: 0;
}

/* 表单项目 */
.form-item {
  background-color: white;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.05);
  transition: all 0.3s ease;
}

.form-item:active {
  transform: translateY(2rpx);
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.05);
}

.form-item__label {
  font-size: 26rpx;
  font-weight: 500;
  color: #2c3e50;
  margin-bottom: 16rpx;
  display: block;
  letter-spacing: 0.5rpx;
}

.form-item__input {
  font-size: 26rpx;
  color: #2c3e50;
  padding: 18rpx 20rpx;
  border: 1rpx solid #e6e9ed;
  border-radius: 12rpx;
  background-color: #fafbfc;
  transition: all 0.3s ease;
}

.form-item__input:focus {
  border-color: #95a5a6;
  background-color: white;
}

.form-item__textarea {
  font-size: 26rpx;
  color: #2c3e50;
  padding: 18rpx 20rpx;
  border: 1rpx solid #e6e9ed;
  border-radius: 12rpx;
  background-color: #fafbfc;
  min-height: 200rpx;
  resize: none;
  transition: all 0.3s ease;
  width: 100%;
  box-sizing: border-box;
}

.form-item__textarea:focus {
  border-color: #95a5a6;
  background-color: white;
}

/* 图片上传 */
.image-uploader {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.uploaded-images {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.uploaded-image {
  position: relative;
  width: 130rpx;
  height: 130rpx;
  border-radius: 12rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.1);
}

.uploaded-image image {
  width: 100%;
  height: 100%;
  object-fit: cover;
}

.delete-image {
  position: absolute;
  top: 8rpx;
  right: 8rpx;
  width: 36rpx;
  height: 36rpx;
  background-color: rgba(255, 255, 255, 0.9);
  color: #e74c3c;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  cursor: pointer;
  border-radius: 50%;
  box-shadow: 0 2rpx 6rpx rgba(0, 0, 0, 0.15);
  transition: all 0.3s ease;
}

.delete-image:active {
  transform: scale(0.9);
}

.upload-button {
  width: 130rpx;
  height: 130rpx;
  border: 2rpx dashed #dce4ec;
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background-color: #f8f9fa;
  cursor: pointer;
  transition: all 0.3s ease;
}

.upload-button:active {
  background-color: #e9ecef;
}

.upload-button text {
  font-size: 48rpx;
  color: #95a5a6;
  font-weight: 300;
}

/* 主图 */
.main-image-container {
  width: 100%;
  padding-top: 100%;
  position: relative;
  border-radius: 12rpx;
  overflow: hidden;
  border: 1rpx solid #e6e9ed;
  background-color: #f8f9fa;
  transition: all 0.3s ease;
}

.main-image-container:active {
  border-color: #95a5a6;
}

.main-image {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  object-fit: cover;
}

.main-image-placeholder {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background-color: #f8f9fa;
  display: flex;
  align-items: center;
  justify-content: center;
  cursor: pointer;
}

.main-image-placeholder text {
  font-size: 26rpx;
  color: #95a5a6;
  letter-spacing: 1rpx;
}

/* 固定在底部的提交按钮 */
.fixed-submit {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 24rpx;
  background: rgba(255, 255, 255, 0.8);
  backdrop-filter: blur(10rpx);
  -webkit-backdrop-filter: blur(10rpx);
  border-top: 1rpx solid rgba(229, 231, 235, 0.8);
  z-index: 100;
}

.submit-button {
  width: 100%;
  height: 92rpx;
  font-size: 32rpx;
  font-weight: 500;
  border-radius: 46rpx;
  background-color: #2c3e50;
  color: white;
  box-shadow: 0 6rpx 20rpx rgba(44, 62, 80, 0.3);
  transition: all 0.3s ease;
  display: flex;
  align-items: center;
  justify-content: center;
}

.submit-button:active {
  transform: translateY(2rpx);
  box-shadow: 0 3rpx 10rpx rgba(44, 62, 80, 0.3);
}

/* 开关样式 */
.form-item__switch {
  transform: scale(1.2);
  margin-left: auto;
}

/* 提示文本 */
.form-item__hint {
  font-size: 22rpx;
  color: #95a5a6;
  margin-top: 12rpx;
  display: block;
  letter-spacing: 0.5rpx;
}

/* 状态切换 */
.status-toggle {
  width: 100%;
}

/* 响应式设计 */
@media (min-width: 750rpx) {
  .form-item {
    padding: 28rpx;
  }
  
  .form-item__label {
    font-size: 28rpx;
  }
  
  .form-item__input,
  .form-item__textarea {
    font-size: 28rpx;
  }
  
  .form-item__hint {
    font-size: 24rpx;
  }
}
