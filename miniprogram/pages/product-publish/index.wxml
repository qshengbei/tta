<!-- pages/admin/product-publish/index.wxml -->
<view class="product-publish">


  <!-- 商品表单 -->
  <form bindsubmit="submitForm" class="product-form">
    <!-- 商品名称 -->
    <view class="form-item">
      <text class="form-item__label">商品名称</text>
      <input 
        class="form-item__input" 
        placeholder="请输入商品名称" 
        value="{{product.name}}" 
        bindinput="inputName"
      />
    </view>

    <!-- 商品描述 -->
    <view class="form-item">
      <text class="form-item__label">商品描述</text>
      <textarea 
        class="form-item__textarea" 
        placeholder="请输入商品描述" 
        value="{{product.description}}" 
        bindinput="inputDescription"
        maxlength="500"
      />
    </view>

    <!-- 商品价格 -->
    <view class="form-item">
      <text class="form-item__label">商品价格</text>
      <input 
        class="form-item__input" 
        placeholder="请输入商品价格" 
        value="{{product.price}}" 
        bindinput="inputPrice"
        type="number"
      />
    </view>

    <!-- 商品库存 -->
    <view class="form-item">
      <text class="form-item__label">商品库存</text>
      <input 
        class="form-item__input" 
        placeholder="请输入商品库存" 
        value="{{product.stock}}" 
        bindinput="inputStock"
        type="number"
      />
    </view>

    <!-- 商品分类 -->
    <view class="form-item">
      <text class="form-item__label">商品分类</text>
      <picker bindchange="onTypeChange" value="{{typeIndex}}" range="{{typeOptions}}" range-key="name">
        <view class="form-item__input">{{typeOptions[typeIndex] && typeOptions[typeIndex].name ? typeOptions[typeIndex].name : '请选择商品分类'}}</view>
      </picker>
    </view>

    <!-- 商品系列 -->
    <view class="form-item">
      <text class="form-item__label">商品系列</text>
      <picker bindchange="onCategoryChange" value="{{categoryIndex}}" range="{{categoryOptions}}" range-key="name">
        <view class="form-item__input">{{categoryOptions[categoryIndex] && categoryOptions[categoryIndex].name ? categoryOptions[categoryIndex].name : '请选择商品系列'}}</view>
      </picker>
    </view>

    <!-- 布料选择 -->
    <view class="form-item">
      <text class="form-item__label">布料</text>
      <picker bindchange="onMaterialChange" value="{{materialIndex}}" range="{{materialOptions}}" range-key="name">
        <view class="form-item__input">{{materialOptions[materialIndex] && materialOptions[materialIndex].name ? materialOptions[materialIndex].name : '请选择布料'}}</view>
      </picker>
    </view>

    <!-- 上架状态 -->
    <view class="form-item">
      <text class="form-item__label">上架状态</text>
      <view class="status-toggle">
        <picker bindchange="onStatusChange" value="{{statusIndex}}" range="{{statusOptions}}" range-key="name">
          <view class="form-item__input">{{statusOptions[statusIndex] && statusOptions[statusIndex].name ? statusOptions[statusIndex].name : '请选择状态'}}</view>
        </picker>
      </view>
    </view>

    <!-- 是否新品 -->
    <view class="form-item">
      <text class="form-item__label">是否新品</text>
      <switch 
        class="form-item__switch" 
        checked="{{product.isNew}}" 
        bindchange="onIsNewChange"
      />
    </view>

    <!-- 是否支持七天无理由退换货 -->
    <view class="form-item">
      <text class="form-item__label">是否支持七天无理由退换货</text>
      <switch 
        class="form-item__switch" 
        checked="{{product.supportNoReasonReturn}}" 
        bindchange="onSupportNoReasonReturnChange"
      />
      <text class="form-item__hint">开启后，用户可以在收到商品7天内申请无理由退货退款</text>
    </view>

    <!-- 商品标签 -->
    <view class="form-item">
      <text class="form-item__label">商品标签</text>
      <input 
        class="form-item__input" 
        placeholder="请输入商品标签，用逗号分隔" 
        value="{{tagsText}}" 
        bindinput="inputTags"
      />
      <text class="form-item__hint">例如：发圈,克莱因蓝,主推</text>
    </view>

    <!-- 商品主图 -->
    <view class="form-item">
      <text class="form-item__label">商品主图</text>
      <view class="main-image-container">
        <image 
          wx:if="{{product.coverImage}}" 
          src="{{product.coverImage}}" 
          mode="aspectFill" 
          class="main-image"
        />
        <view wx:else class="main-image-placeholder" bindtap="chooseCoverImage">
          <text>点击选择主图</text>
        </view>
      </view>
    </view>

    <!-- 商品图片 -->
    <view class="form-item">
      <text class="form-item__label">商品图片</text>
      <view class="image-uploader">
        <view class="uploaded-images">
          <view wx:for="{{product.images}}" wx:key="{{index}}" class="uploaded-image">
            <image src="{{item}}" mode="aspectFill" />
            <view class="delete-image" bindtap="deleteImage" data-index="{{index}}">×</view>
          </view>
        </view>
        <view class="upload-button" bindtap="chooseImage">
          <text>+</text>
        </view>
      </view>
    </view>

  </form>

  <!-- 固定在底部的提交按钮 -->
  <view class="fixed-submit">
    <form bindsubmit="submitForm">
      <button type="primary" form-type="submit" class="submit-button" loading="{{submitting}}">
        {{isEditing ? '保存修改' : '发布商品'}}
      </button>
    </form>
  </view>
</view>