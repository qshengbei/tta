.customer-service {
  width: 100%;
  height: 100vh;
  background-color: #f5f5f5;
  display: flex;
  flex-direction: column;
}

.customer-service__header {
  width: 100%;
  height: 88rpx;
  background-color: #ffffff;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 32rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.1);
  position: sticky;
  top: 0;
  z-index: 100;
}

.customer-service__back {
  width: 44rpx;
  height: 44rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.customer-service__back-icon {
  width: 24rpx;
  height: 24rpx;
  border-left: 4rpx solid #333333;
  border-top: 4rpx solid #333333;
  transform: rotate(-45deg);
}

.customer-service__title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333333;
}

.customer-service__placeholder {
  width: 44rpx;
  height: 44rpx;
}

.customer-service__content {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 64rpx 32rpx;
}

.customer-service__qrcode-container {
  width: 100%;
  max-width: 500rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  background-color: #ffffff;
  border-radius: 16rpx;
  padding: 64rpx 32rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.1);
}

.customer-service__qrcode {
  width: 360rpx;
  height: 360rpx;
  margin-bottom: 32rpx;
}

.customer-service__tip {
  font-size: 28rpx;
  color: #666666;
  text-align: center;
  line-height: 40rpx;
}
