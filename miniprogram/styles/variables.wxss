/* styles/variables.wxss */

/* ===== 设计 Token：色彩、字体、间距 ===== */

/* 色彩 */
:root {
  /* Brand */
  --color-primary: #1a3d8f;
  --color-primary-soft: #e5ecfa;

  /* Neutrals */
  --color-bg: #ffffff;
  --color-bg-alt: #f5f5f5;
  --color-bg-elevated: #ffffff;
  --color-border-subtle: #eaeaea;

  --color-text-main: #111111;
  --color-text-secondary: #666666;
  --color-text-muted: #999999;

  /* Feedback */
  --color-success: #0ebc6c;
  --color-warning: #ff9f40;
  --color-danger: #e34c4c;
}

/* 字体 */
:root {
  --font-family-base: -apple-system, BlinkMacSystemFont, "Helvetica Neue",
    Helvetica, "PingFang SC", "Hiragino Sans GB", "Microsoft YaHei", Arial,
    sans-serif;

  --font-size-display: 40rpx;
  --font-size-h1: 32rpx;
  --font-size-h2: 28rpx;
  --font-size-body: 26rpx;
  --font-size-body-sm: 24rpx;
  --font-size-caption: 22rpx;
}

/* 间距 */
:root {
  --space-xs: 8rpx;
  --space-sm: 16rpx;
  --space-md: 24rpx;
  --space-lg: 32rpx;
  --space-xl: 40rpx;
}