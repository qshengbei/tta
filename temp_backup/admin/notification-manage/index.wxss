.notification-manage {
  min-height: 100vh;
  background-color: #f5f5f5;
}

/* 顶部导航栏 */
.navbar {
  background-color: #fff;
  padding: 20rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.1);
  position: sticky;
  top: 0;
  z-index: 100;
}

.title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  text-align: center;
}

/* 标签切换 */
.tab-bar {
  display: flex;
  background-color: #fff;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 4rpx rgba(0, 0, 0, 0.05);
}

.tab-item {
  flex: 1;
  text-align: center;
  padding: 20rpx 0;
  font-size: 28rpx;
  color: #666;
  border-bottom: 2rpx solid transparent;
}

.tab-item.active {
  color: #007aff;
  border-bottom-color: #007aff;
  font-weight: bold;
}

/* 表单样式 */
.notification-form {
  background-color: #fff;
  padding: 20rpx;
  margin: 20rpx;
  border-radius: 10rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
}

.form-item {
  margin-bottom: 30rpx;
}

.label {
  display: block;
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 10rpx;
}

.input,
.textarea,
.picker {
  width: 100%;
  padding: 15rpx;
  border: 1rpx solid #e0e0e0;
  border-radius: 5rpx;
  font-size: 26rpx;
  color: #333;
  background-color: #f9f9f9;
}

.textarea {
  resize: none;
}

.picker {
  display: flex;
  align-items: center;
  justify-content: space-between;
  background-color: #f9f9f9;
}

.submit-btn {
  width: 100%;
  padding: 20rpx;
  background-color: #007aff;
  color: #fff;
  font-size: 30rpx;
  font-weight: bold;
  border-radius: 5rpx;
  margin-top: 20rpx;
}

/* 空状态 */
.empty-state {
  display: flex;
  justify-content: center;
  align-items: center;
  height: 400rpx;
  color: #999;
  font-size: 28rpx;
}

/* 补货通知列表 */
.restock-list {
  padding: 20rpx;
}

.restock-item {
  background-color: #fff;
  border-radius: 10rpx;
  padding: 20rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
  position: relative;
}

.restock-item-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 15rpx;
}

.product-name {
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
  flex: 1;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.status {
  font-size: 24rpx;
  padding: 5rpx 15rpx;
  border-radius: 15rpx;
  background-color: #f0f0f0;
  color: #666;
}

.restock-item-body {
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
}

.product-image {
  width: 120rpx;
  height: 120rpx;
  border-radius: 5rpx;
  margin-right: 20rpx;
}

.product-info {
  flex: 1;
}

.price {
  font-size: 30rpx;
  font-weight: bold;
  color: #ff6b6b;
  margin-bottom: 10rpx;
  display: block;
}

.user-count {
  font-size: 24rpx;
  color: #666;
}

.restock-item-footer {
  display: flex;
  justify-content: flex-end;
  align-items: center;
}

.process-btn {
  padding: 10rpx 20rpx;
  border: 1rpx solid #007aff;
  color: #007aff;
  background-color: #fff;
  font-size: 24rpx;
  border-radius: 5rpx;
  margin-right: 15rpx;
}

.restock-btn {
  padding: 10rpx 20rpx;
  background-color: #52c41a;
  color: #fff;
  font-size: 24rpx;
  border-radius: 5rpx;
}

.processed-text {
  font-size: 24rpx;
  color: #999;
}

/* 用户列表弹窗 */
.user-list-modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(0, 0, 0, 0.5);
  display: flex;
  justify-content: center;
  align-items: center;
  z-index: 1000;
}

.user-list-content {
  background-color: #fff;
  border-radius: 10rpx;
  width: 80%;
  max-height: 80vh;
  overflow: hidden;
}

.user-list-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx;
  border-bottom: 1rpx solid #e0e0e0;
}

.user-list-title {
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
}

.close-btn {
  font-size: 36rpx;
  color: #999;
}

.user-list {
  max-height: 60vh;
  overflow-y: auto;
  padding: 20rpx;
}

.user-item {
  display: flex;
  align-items: center;
  padding: 15rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.user-avatar {
  width: 60rpx;
  height: 60rpx;
  border-radius: 50%;
  margin-right: 15rpx;
}

.user-info {
  flex: 1;
}

.user-name {
  font-size: 26rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 5rpx;
  display: block;
}

.request-time,
.request-count {
  font-size: 22rpx;
  color: #666;
  margin-bottom: 3rpx;
  display: block;
}

/* 加载状态 */
.loading {
  display: flex;
  justify-content: center;
  align-items: center;
  padding: 20rpx;
}

/* 响应式调整 */
@media (max-width: 375px) {
  .product-name {
    font-size: 26rpx;
  }
  
  .price {
    font-size: 28rpx;
  }
  
  .user-count {
    font-size: 22rpx;
  }
  
  .process-btn,
  .restock-btn {
    font-size: 22rpx;
    padding: 8rpx 16rpx;
  }
}
