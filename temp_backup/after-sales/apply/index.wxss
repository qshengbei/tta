/* pages/after-sales/apply/index.wxss */
.page-root {
  min-height: 100vh;
  background-color: #f5f5f5;
}

.header {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  display: flex;
  align-items: center;
  justify-content: space-between;
  height: 88rpx;
  background-color: #fff;
  padding: 0 24rpx;
  border-bottom: 1rpx solid #e5e5e5;
  z-index: 100;
}

.header__back {
  width: 60rpx;
  height: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.header__back-icon {
  font-size: 40rpx;
  color: #333;
}

.header__title {
  font-size: 32rpx;
  font-weight: 500;
  color: #333;
}

.header__placeholder {
  width: 60rpx;
}

.content {
  padding: 108rpx 24rpx 160rpx;
}

.order-info {
  background-color: #fff;
  border-radius: 12rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
}

.order-info__order-no {
  font-size: 24rpx;
  color: #999;
  margin-bottom: 20rpx;
}

.order-info__product {
  display: flex;
  align-items: flex-start;
}

.order-info__product-image {
  width: 160rpx;
  height: 160rpx;
  border-radius: 8rpx;
  background-color: #f5f5f5;
  margin-right: 20rpx;
}

.order-info__product-info {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.order-info__product-name {
  font-size: 28rpx;
  color: #333;
  line-height: 1.4;
  margin-bottom: 8rpx;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  overflow: hidden;
}

.order-info__product-spec {
  font-size: 24rpx;
  color: #999;
  margin-bottom: 12rpx;
}

.order-info__product-price {
  font-size: 32rpx;
  font-weight: 600;
  color: #ff4d4f;
}

.reason-info {
  background-color: #fff;
  border-radius: 12rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
}

.reason-info__item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
}

.reason-info__item:last-child {
  border-bottom: none;
}

.reason-info__label {
  font-size: 26rpx;
  color: #999;
}

.reason-info__value {
  font-size: 26rpx;
  color: #333;
}

.step-section {
  background-color: #fff;
  border-radius: 12rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
}

.step-section__header {
  display: flex;
