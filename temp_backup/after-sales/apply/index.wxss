  align-items: center;
  margin-bottom: 16rpx;
}

.step-section__title {
  font-size: 28rpx;
  font-weight: 500;
  color: #333;
}

.step-section__hint {
  font-size: 24rpx;
  color: #999;
}

.step-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16rpx 0;
}

.step-item__value {
  font-size: 28rpx;
  color: #333;
}

.step-item__arrow {
  font-size: 32rpx;
