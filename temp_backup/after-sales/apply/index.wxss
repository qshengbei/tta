}

.amount-input__field {
  font-size: 36rpx;
  font-weight: 600;
  color: #333;
  border: none;
  outline: none;
  background: transparent;
  width: auto;
  min-width: 60rpx;
  max-width: 200rpx;
  padding: 0;
  text-align: left;
}

/* 编辑按钮固定右侧 */
/* 编辑按钮紧贴金额输入框 */
.amount-input__edit-btn {
  margin-left: 0;
  flex-shrink: 0;
  font-size: 28rpx;
  color: #1890ff;
  background: none;
  border: none;
  padding: 0 8rpx;
  height: 48rpx;
  line-height: 48rpx;
}

.contact-section {
  background-color: #fff;
  border-radius: 12rpx;
  padding: 24rpx;
}

.contact-section__header {
  margin-bottom: 16rpx;
}

.contact-section__title {
  font-size: 28rpx;
  font-weight: 500;
  color: #333;
}

.contact-item {
  display: flex;
  align-items: center;
  padding: 16rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.contact-item:last-child {
  border-bottom: none;
}

.contact-item__label {
  width: 120rpx;
  font-size: 26rpx;
  color: #666;
}

.contact-item__input {
  flex: 1;
  font-size: 26rpx;
  color: #333;
}

.footer {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background-color: #fff;
  padding: 20rpx 24rpx;
  border-top: 1rpx solid #e5e5e5;
}

.footer__submit {
  width: 100%;
  height: 88rpx;
  background-color: #ff4d4f;
  color: #fff;
  font-size: 32rpx;
  font-weight: 500;
  border-radius: 44rpx;
  line-height: 88rpx;
}

.footer__submit::after {
  border: none;
}

.modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 200;
  display: flex;
  align-items: flex-end;
  justify-content: center;
}

.modal__mask {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(0, 0, 0, 0.5);
}

.modal__content {
  position: relative;
  width: 100%;
  background-color: #fff;
  border-radius: 20rpx 20rpx 0 0;
  max-height: 70vh;
  overflow: hidden;
}

.modal__content--large {
  max-height: 80vh;
}

.modal__header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 28rpx 32rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.modal__title {
  font-size: 32rpx;
  font-weight: 500;
  color: #333;
}

.modal__close {
  width: 48rpx;
  height: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
  color: #999;
}

.modal__body {
  padding: 16rpx 0;
  max-height: calc(70vh - 100rpx);
  overflow-y: auto;
}

.modal__content--large .modal__body {
  max-height: calc(80vh - 100rpx);
}

.modal__item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 28rpx 32rpx;
  border-bottom: 1rpx solid #f5f5f5;
}

.modal__item:last-child {
  border-bottom: none;
}

.modal__item-info {
  flex: 1;
}

.modal__item-name {
  font-size: 28rpx;
  color: #333;
}

.modal__item-desc {
  font-size: 24rpx;
  color: #999;
  margin-top: 6rpx;
  display: block;
}

.modal__item-check {
  width: 40rpx;
  height: 40rpx;
  border: 2rpx solid #d9d9d9;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  color: transparent;
}

.modal__item:active .modal__item-check {
  background-color: #ff4d4f;
  border-color: #ff4d4f;
  color: #fff;
}

/* 未收到货退款提示样式 */
.warning-section {
  display: flex;
  align-items: flex-start;
  background-color: #fffbe6;
  border: 1rpx solid #ffe58f;
  border-radius: 12rpx;
  padding: 20rpx;
  margin-bottom: 20rpx;
}

.warning-section__icon {
  font-size: 40rpx;
  margin-right: 16rpx;
  flex-shrink: 0;
}

.warning-section__content {
  flex: 1;
}

.warning-section__title {
  font-size: 26rpx;
  font-weight: 500;
  color: #faad14;
  margin-bottom: 8rpx;
  display: block;
}

.warning-section__text {
  font-size: 24rpx;
  color: #d48806;
  line-height: 1.5;
}