/* pages/after-sales/exchange/index.wxss */
.page-root {
  min-height: 100vh;
  background-color: #f5f5f5;
}

.header {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  display: flex;
  align-items: center;
  justify-content: space-between;
  height: 88rpx;
  background-color: #fff;
  padding: 0 24rpx;
  border-bottom: 1rpx solid #e5e5e5;
  z-index: 100;
}

.header__back {
  width: 60rpx;
  height: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.header__back-icon {
  font-size: 40rpx;
  color: #333;
}

.header__title {
  font-size: 32rpx;
  font-weight: 500;
  color: #333;
}

.header__placeholder {
  width: 60rpx;
}

.content {
  padding: 108rpx 24rpx 160rpx;
}

.order-info {
  background-color: #fff;
  border-radius: 12rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
}

.order-info__order-no {
  font-size: 24rpx;
  color: #999;
  margin-bottom: 20rpx;
}

.order-info__product {
  display: flex;
  align-items: flex-start;
}

.order-info__product-image {
  width: 160rpx;
  height: 160rpx;
  border-radius: 8rpx;
  background-color: #f5f5f5;
  margin-right: 20rpx;
}

.order-info__product-info {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.order-info__product-name {
  font-size: 28rpx;
  color: #333;
  line-height: 1.4;
  margin-bottom: 8rpx;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  overflow: hidden;
}

.order-info__product-spec {
  font-size: 24rpx;
  color: #999;
  margin-bottom: 12rpx;
}

.order-info__product-price {
  font-size: 32rpx;
  font-weight: 600;
  color: #ff4d4f;
}

.reason-info {
  background-color: #fff;
  border-radius: 12rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
}

.reason-info__item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
}

.reason-info__item:last-child {
  border-bottom: none;
}

.reason-info__label {
  font-size: 26rpx;
  color: #999;
}

.reason-info__value {
  font-size: 26rpx;
  color: #333;
}

.step-section {
  background-color: #fff;
  border-radius: 12rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
}

.step-section__header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.step-section__title {
  font-size: 28rpx;
  font-weight: 500;
  color: #333;
}

.step-section__hint {
  font-size: 24rpx;
  color: #999;
}

.step-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16rpx 0;
}

.step-item__value {
  font-size: 28rpx;
  color: #333;
}

.step-item__arrow {
  font-size: 32rpx;
  color: #ccc;
}

.meta-info {
  background-color: #fff;
  border-radius: 12rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
}

.meta-info__row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 12rpx 0;
}

.meta-info__label {
  font-size: 26rpx;
  color: #666;
}

.meta-info__value {
  font-size: 26rpx;
  color: #333;
}

.address-section {
  background-color: #fff;
  border-radius: 12rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
}

.address-section__header {
  margin-bottom: 16rpx;
}

.address-section__title {
  font-size: 28rpx;
  font-weight: 500;
  color: #333;
}

.address-info {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
}

.address-info__text {
  flex: 1;
  font-size: 26rpx;
  color: #333;
  line-height: 1.6;
}

.address-info__actions {
  display: flex;
  gap: 20rpx;
}

.address-info__action {
  font-size: 24rpx;
  color: #1890ff;
}

.upload-section {
  background-color: #fff;
  border-radius: 12rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
}

.upload-section__header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.upload-section__title {
  font-size: 28rpx;
  font-weight: 500;
  color: #333;
}

.upload-section__hint {
  font-size: 24rpx;
  color: #999;
}

.upload-section__textarea {
  width: 100%;
  height: 160rpx;
  border: 2rpx solid #e5e5e5;
  border-radius: 8rpx;
  padding: 20rpx;
  font-size: 26rpx;
  color: #333;
  resize: none;
  box-sizing: border-box;
  margin-bottom: 20rpx;
}

.upload-container {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.upload-item {
  width: 140rpx;
  height: 140rpx;
  border-radius: 8rpx;
  position: relative;
}

.upload-item--image {
  border: none;
}

.upload-item--add {
  border: 2rpx dashed #d9d9d9;
  display: flex;
  align-items: center;
  justify-content: center;
}

.upload-item__image {
  width: 100%;
  height: 100%;
  border-radius: 8rpx;
}

.upload-item__delete {
  position: absolute;
  top: -16rpx;
  right: -16rpx;
  width: 36rpx;
  height: 36rpx;
  background-color: rgba(0, 0, 0, 0.6);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  color: #fff;
}

.upload-item__add-icon {
  font-size: 48rpx;
  color: #999;
}

.contact-section {
  background-color: #fff;
  border-radius: 12rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
}

.contact-section__header {
  margin-bottom: 16rpx;
}

.contact-section__title {
  font-size: 28rpx;
  font-weight: 500;
  color: #333;
}

.contact-item {
  display: flex;
  align-items: center;
  padding: 16rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.contact-item:last-child {
  border-bottom: none;
}

.contact-item__label {
  width: 120rpx;
  font-size: 26rpx;
  color: #666;
}

.contact-item__input {
  flex: 1;
  font-size: 26rpx;
  color: #333;
}

.tip-section {
  background-color: #fffbe6;
  border-radius: 12rpx;
  padding: 20rpx;
  margin-bottom: 20rpx;
}

.tip-section__text {
  font-size: 24rpx;
  color: #ad8b00;
  line-height: 1.6;
}

.footer {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background-color: #fff;
  padding: 20rpx 24rpx;
  border-top: 1rpx solid #e5e5e5;
}

.footer__submit {
  width: 100%;
  height: 88rpx;
  background-color: #ff4d4f;
  color: #fff;
  font-size: 32rpx;
  font-weight: 500;
  border-radius: 44rpx;
  line-height: 88rpx;
}

.footer__submit::after {
  border: none;
}

.modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 200;
  display: flex;
  align-items: flex-end;
  justify-content: center;
}

.modal__mask {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(0, 0, 0, 0.5);
}

.modal__content {
  position: relative;
  width: 100%;
  background-color: #fff;
  border-radius: 20rpx 20rpx 0 0;
  max-height: 70vh;
  overflow: hidden;
}

.modal__header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 28rpx 32rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.modal__title {
  font-size: 32rpx;
  font-weight: 500;
  color: #333;
}

.modal__close {
  width: 48rpx;
  height: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
  color: #999;
}

.modal__body {
  padding: 16rpx 0;
  max-height: calc(70vh - 100rpx);
  overflow-y: auto;
}

.modal__item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 28rpx 32rpx;
  border-bottom: 1rpx solid #f5f5f5;
}

.modal__item:last-child {
  border-bottom: none;
}

.modal__item-name {
  font-size: 28rpx;
  color: #333;
}

.modal__item-check {
  width: 40rpx;
  height: 40rpx;
  border: 2rpx solid #d9d9d9;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  color: transparent;
}

.modal__item:active .modal__item-check {
  background-color: #ff4d4f;
  border-color: #ff4d4f;
  color: #fff;
}

.modal__product-info {
  display: flex;
  padding: 20rpx 32rpx;
  border-bottom: 1rpx solid #f5f5f5;
}

.modal__product-image {
  width: 120rpx;
  height: 120rpx;
  border-radius: 8rpx;
  background-color: #f5f5f5;
  margin-right: 20rpx;
}

.modal__product-details {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.modal__product-name {
  font-size: 26rpx;
  color: #333;
  margin-bottom: 8rpx;
}

.modal__product-spec {
  font-size: 24rpx;
  color: #999;
}

.modal__spec-list {
  padding: 16rpx 32rpx;
}

.modal__spec-title {
  font-size: 24rpx;
  color: #999;
  margin-bottom: 16rpx;
}

.modal__spec-item {
  padding: 20rpx;
  background-color: #f8f9fa;
  border-radius: 8rpx;
  font-size: 26rpx;
  color: #333;
  margin-bottom: 12rpx;
}

.modal__spec-item:last-child {
  margin-bottom: 0;
}