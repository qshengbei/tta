/* pages/logistics/index.wxss */
.page-root {
  background-color: #f5f5f5;
  min-height: 100vh;
}

/* 头部 */
.header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 45rpx 30rpx 30rpx;
  background-color: #1989fa;
  color: white;
  position: sticky;
  top: 0;
  z-index: 100;
}

.header__left {
  width: 60rpx;
  height: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.header__back {
  width: 32rpx;
  height: 32rpx;
}

.header__title {
  font-size: 32rpx;
  font-weight: bold;
}

.header__right {
  width: 60rpx;
}

/* 加载状态 */
.loading {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 100rpx 0;
}

.loading__spinner {
  width: 60rpx;
  height: 60rpx;
  border: 4rpx solid rgba(0, 0, 0, 0.1);
  border-left-color: #1989fa;
  border-radius: 50%;
  animation: spin 1s linear infinite;
  margin-bottom: 20rpx;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.loading__text {
  font-size: 28rpx;
  color: #666;
}

/* 错误状态 */
.error {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 100rpx 0;
}

.error__text {
  font-size: 28rpx;
  color: #666;
  margin-bottom: 30rpx;
  text-align: center;
  padding: 0 30rpx;
}

.btn {
  padding: 15rpx 40rpx;
  border-radius: 20rpx;
  font-size: 26rpx;
  font-weight: bold;
}

.btn-secondary {
  background-color: #f0f0f0;
  color: #333;
  border: 2rpx solid #e0e0e0;
}

/* 内容区域 */
.content {
  padding: 30rpx;
}

/* 物流基本信息 */
.logistics-info {
  background-color: white;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.08);
}

.logistics-info__item {
  display: flex;
  margin-bottom: 20rpx;
  align-items: center;
}

.logistics-info__item:last-child {
  margin-bottom: 0;
}

.logistics-info__label {
  font-size: 26rpx;
  color: #666;
  width: 160rpx;
  flex-shrink: 0;
}

.logistics-info__value {
  font-size: 26rpx;
  color: #333;
  flex: 1;
  word-break: break-all;
}

.logistics-info__value--status {
  font-weight: bold;
}

/* 物流轨迹 */
.logistics-timeline {
  background-color: white;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.08);
}

.logistics-timeline__title {
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 30rpx;
}

.logistics-timeline__item {
  display: flex;
  margin-bottom: 30rpx;
  position: relative;
}

.logistics-timeline__item:last-child {
  margin-bottom: 0;
}

.logistics-timeline__node {
  width: 60rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  flex-shrink: 0;
}

.logistics-timeline__dot {
  width: 20rpx;
  height: 20rpx;
  border-radius: 50%;
  background-color: #e0e0e0;
  margin-bottom: 10rpx;
  position: relative;
  z-index: 2;
}

.logistics-timeline__dot--active {
  background-color: #1989fa;
  width: 24rpx;
  height: 24rpx;
  box-shadow: 0 0 0 8rpx rgba(25, 137, 250, 0.1);
}

.logistics-timeline__line {
  width: 2rpx;
  flex: 1;
  background-color: #e0e0e0;
  margin-top: -10rpx;
  position: relative;
  z-index: 1;
}

.logistics-timeline__content {
  flex: 1;
  padding-left: 20rpx;
  padding-bottom: 30rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.logistics-timeline__item:last-child .logistics-timeline__content {
  border-bottom: none;
  padding-bottom: 0;
}

.logistics-timeline__text {
  font-size: 26rpx;
  color: #333;
  line-height: 36rpx;
  margin-bottom: 10rpx;
  display: block;
}

.logistics-timeline__time {
  font-size: 22rpx;
  color: #999;
  display: block;
}

/* 地图轨迹 */
.map-section {
  background-color: white;
  border-radius: 16rpx;
  padding: 30rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.08);
}

.map-section__title {
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 20rpx;
}

.map-container {
  width: 100%;
  height: 400rpx;
  border-radius: 12rpx;
  overflow: hidden;
  background-color: #f5f5f5;
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
}

.map-placeholder {
  width: 100%;
  height: 100%;
  object-fit: cover;
  opacity: 0.5;
}

.map-placeholder-text {
  position: absolute;
  font-size: 26rpx;
  color: #666;
  text-align: center;
  padding: 0 30rpx;
}